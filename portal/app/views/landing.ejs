<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { couple, title: null, extraStyles: [] }) %>
<body>

  <%- include('partials/topbar', { couple, currentPage }) %>

  <!-- ── Hero ────────────────────────────────────────────────────────────── -->
  <section class="hero<%= couple.hero_text_color === 'light' ? ' hero--light-text' : '' %>">
    <div class="hero-photo" aria-hidden="true"
         <% if (couple.hero_photo_url) { %>style="background-image: linear-gradient(rgba(0,0,0,0.38), rgba(0,0,0,0.38)), url('<%= couple.hero_photo_url %>'); background-position: <%= couple.hero_bg_position_x ?? 50 %>% <%= couple.hero_bg_position_y ?? 50 %>%;"<% } %>>
    </div>

    <div class="hero-inner">
      <div class="hero-venue">
        <% if (couple.venue_name) { %>
          <%= couple.venue_name %><% if (couple.venue_location) { %> · <%= couple.venue_location %><% } %>
        <% } %>
      </div>
      <h1 class="hero-names"><%= couple.display_name %></h1>
      <div class="hero-subtitle"><%= couple.hero_subtitle %></div>
      <div class="hero-date"><%= formattedDate %></div>

      <div class="hero-countdown" id="hero-countdown">
        <span class="countdown-unit"><span class="countdown-num" id="cd-days">--</span><span class="countdown-label">Days</span></span>
        <span class="countdown-sep">·</span>
        <span class="countdown-unit"><span class="countdown-num" id="cd-hours">--</span><span class="countdown-label">Hours</span></span>
        <span class="countdown-sep">·</span>
        <span class="countdown-unit"><span class="countdown-num" id="cd-mins">--</span><span class="countdown-label">Minutes</span></span>
        <span class="countdown-sep">·</span>
        <span class="countdown-unit"><span class="countdown-num" id="cd-secs">--</span><span class="countdown-label">Seconds</span></span>
      </div>
    </div>
  </section>

  <!-- ── Intro strip ─────────────────────────────────────────────────────── -->
  <section class="intro">
    <span class="label intro-label">Prepared for <%= couple.display_name %></span>
    <% if (couple.intro_text) { %>
      <p class="intro-text"><%= couple.intro_text %></p>
    <% } %>
    <% if (couple.intro_tagline) { %>
      <p class="intro-tagline"><%= couple.intro_tagline %></p>
    <% } %>
  </section>

  <!-- ── Meet your team ────────────────────────────────────────────────── -->
  <% if (typeof teamMembers !== 'undefined' && teamMembers.length > 0) { %>
  <section class="team">
    <div class="team-inner">
      <span class="label team-eyebrow">Your team</span>
      <h2 class="team-heading"><em>The people behind the process.</em></h2>
      <div class="team-cards">
        <% teamMembers.forEach(m => {
             const initials = m.name.split(' ').map(w => w[0]).slice(0, 2).join('');
        %>
        <article class="team-card">
          <div class="team-photo-wrap">
            <% if (m.photo_url) { %>
              <img src="<%= m.photo_url %>" alt="<%= m.name %>" class="team-photo-img">
            <% } else { %>
              <span class="team-initials"><%= initials %></span>
            <% } %>
          </div>
          <div class="team-info">
            <div class="team-name"><%= m.name %></div>
            <% if (m.role) { %><div class="team-role"><%= m.role %></div><% } %>
            <% if (m.bio) { %><p class="team-bio"><%= m.bio %></p><% } %>
          </div>
        </article>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <%- include('partials/footer', { couple }) %>

  <script>
    (function () {
      var dateStr = '<%= couple.wedding_date %>';
      if (!dateStr) return;
      var target = new Date(dateStr);
      target.setUTCHours(0, 0, 0, 0);
      var daysEl  = document.getElementById('cd-days');
      var hoursEl = document.getElementById('cd-hours');
      var minsEl  = document.getElementById('cd-mins');
      var secsEl  = document.getElementById('cd-secs');
      var wrap    = document.getElementById('hero-countdown');
      function tick() {
        var diff = target - new Date();
        if (diff <= 0) {
          wrap.innerHTML = '<span class="countdown-wedding-day">Today is the day.</span>';
          return;
        }
        daysEl.textContent  = Math.floor(diff / 86400000);
        hoursEl.textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
        minsEl.textContent  = String(Math.floor((diff % 3600000)  / 60000)).padStart(2, '0');
        secsEl.textContent  = String(Math.floor((diff % 60000)    / 1000)).padStart(2, '0');
      }
      tick();
      setInterval(tick, 1000);
    })();
  </script>

</body>
</html>
