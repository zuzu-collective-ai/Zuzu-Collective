<%# Footer — same on every page. %>
<footer class="footer">
  <p class="footer-cta">
    Have questions? <a href="mailto:info@zuzucollective.com">Let's chat.</a>
  </p>

  <div class="footer-signature">
    <div class="name display">Zoe McDaniel</div>
    <div class="title">Founder &amp; Creative Director</div>
    <div class="mono" style="margin-top: .25rem;">Zuzu Collective</div>

    <div class="footer-taglines">
      Bespoke weddings &amp; events that escape the mundane.<br>
      Story-driven design rooted in intention.
    </div>
  </div>

  <div class="footer-meta">
    Zuzu Collective · San Diego
    <span class="footer-sep">·</span>
    portal.zuzucollective.com / <%= couple.slug %>
  </div>
</footer>

<script>
  // Cormorant Garamond's italic hyphen sits at a steep angle.
  // Wrap hyphens and dashes inside <em> elements with an upright span.
  document.querySelectorAll('em').forEach(function(el) {
    if (!el.querySelector('*') && /[-–—]/.test(el.textContent)) {
      el.innerHTML = el.textContent.replace(/[-–—]/g, function(ch) {
        return '<span style="font-style:normal">' + ch + '</span>';
      });
    }
  });
</script>
