<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { couple, title: 'Vendors', extraStyles: ['palette.css', 'vendors.css'] }) %>
<body>

  <%- include('partials/topbar', { couple, currentPage }) %>

  <!-- ── Page header ─────────────────────────────────────────────────────── -->
  <section class="page-header">
    <span class="label page-eyebrow"><%= couple.display_name %></span>
    <h1 class="page-title">Vendors</h1>
    <p class="page-subtitle">
      The team behind October tenth. Each vendor with their contact details — booked,
      in conversation, or still on the shortlist.
    </p>
  </section>

  <!-- ── Summary counts ──────────────────────────────────────────────────── -->
  <section class="section vendors-summary">
    <div class="summary-stats">
      <div class="stat">
        <div class="stat-label">Vendors total</div>
        <div class="stat-number">17</div>
        <div class="stat-note">Across the full team</div>
      </div>
      <div class="stat">
        <div class="stat-label">Booked</div>
        <div class="stat-number stat-number--accent">7</div>
        <div class="stat-note">Contracts signed</div>
      </div>
      <div class="stat">
        <div class="stat-label">Still selecting</div>
        <div class="stat-number">10</div>
        <div class="stat-note">In conversation or shortlisting</div>
      </div>
    </div>
  </section>

  <!-- ── Vendor list ─────────────────────────────────────────────────────── -->
  <section class="section vendor-list">

    <!-- 01 · Venue ────────────────────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">01 · Venue</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>La Playa Hotel</em></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Contact</span>Michael Hernandez</li>
          <li><span class="contact-label">Phone</span><a href="tel:+18316246476">(831) 624-6476</a></li>
          <li><span class="contact-label">Email</span><a href="mailto:events@laplayahotel.com">events@laplayahotel.com</a></li>
          <li><span class="contact-label">Address</span>Camino Real at 8th Ave, Carmel-by-the-Sea, CA</li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 02 · Caterer ──────────────────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">02 · Caterer</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>La Playa Catering</em><span class="vendor-note"> · in-house</span></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Contact</span>Sandra Chen</li>
          <li><span class="contact-label">Phone</span><a href="tel:+18316246476">(831) 624-6476 ext. 2</a></li>
          <li><span class="contact-label">Email</span><a href="mailto:catering@laplayahotel.com">catering@laplayahotel.com</a></li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 03 · Photographer ─────────────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">03 · Photographer</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>Iris &amp; Light Studio</em></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Contact</span>Iris Tanaka</li>
          <li><span class="contact-label">Phone</span><a href="tel:+14155550234">(415) 555-0234</a></li>
          <li><span class="contact-label">Email</span><a href="mailto:iris@irisandlight.com">iris@irisandlight.com</a></li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 04 · Videographer ─────────────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">04 · Videographer</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>Carmel Coast Films</em></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Contact</span>Marcus Wells</li>
          <li><span class="contact-label">Phone</span><a href="tel:+18315550788">(831) 555-0788</a></li>
          <li><span class="contact-label">Email</span><a href="mailto:hello@carmelcoast.com">hello@carmelcoast.com</a></li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 05 · Florist ──────────────────────────────────────────────────── -->
    <article class="vendor is-tbc">
      <div class="vendor-meta">
        <span class="label">05 · Florist</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name vendor-name--tbc"><em>Selecting now</em></h2>
        <p class="vendor-tbc-note">
          Three studios shortlisted. Looking for ivory-forward florals with
          baby's breath, calla lilies, and roses. Decision by end of month.
        </p>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-shortlist">Shortlisting</span>
      </div>
    </article>

    <!-- 06 · DJ ───────────────────────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">06 · DJ</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>West Coast Sound</em></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Contact</span>Daniel Marquez</li>
          <li><span class="contact-label">Phone</span><a href="tel:+14155559923">(415) 555-9923</a></li>
          <li><span class="contact-label">Email</span><a href="mailto:daniel@westcoastsound.com">daniel@westcoastsound.com</a></li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 07 · Band ─────────────────────────────────────────────────────── -->
    <article class="vendor is-na">
      <div class="vendor-meta">
        <span class="label">07 · Band</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name vendor-name--tbc"><em>Not booking — DJ only</em></h2>
        <p class="vendor-tbc-note">
          Couple opted for DJ over band for the reception. Ceremony quartet
          covers live music for the processional.
        </p>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-na">N / A</span>
      </div>
    </article>

    <!-- 08 · Wedding Planner ──────────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">08 · Wedding Planner</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>Zuzu Collective</em></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Contact</span>Zoe McDaniel &amp; Amanda</li>
          <li><span class="contact-label">Phone</span><a href="tel:+13478605573">(347) 860-5573</a></li>
          <li><span class="contact-label">Email</span><a href="mailto:info@zuzucollective.com">info@zuzucollective.com</a></li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 09 · Officiant ────────────────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">09 · Officiant</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>Reverend Diane Marquez</em></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Phone</span><a href="tel:+18315552244">(831) 555-2244</a></li>
          <li><span class="contact-label">Email</span><a href="mailto:diane@coastalceremonies.com">diane@coastalceremonies.com</a></li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 10 · Hair Stylist ─────────────────────────────────────────────── -->
    <article class="vendor is-tbc">
      <div class="vendor-meta">
        <span class="label">10 · Hair Stylist</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name vendor-name--tbc"><em>To be booked</em></h2>
        <p class="vendor-tbc-note">
          Trial scheduled with two finalists in October. Looking for soft,
          undone updo with movement.
        </p>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-shortlist">Shortlisting</span>
      </div>
    </article>

    <!-- 11 · Makeup Artist ────────────────────────────────────────────── -->
    <article class="vendor is-tbc">
      <div class="vendor-meta">
        <span class="label">11 · Makeup Artist</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name vendor-name--tbc"><em>To be booked</em></h2>
        <p class="vendor-tbc-note">
          Bundling with hair stylist trial. Bridal party of four also
          requesting service day-of.
        </p>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-shortlist">Shortlisting</span>
      </div>
    </article>

    <!-- 12 · Transportation ───────────────────────────────────────────── -->
    <article class="vendor is-tbc">
      <div class="vendor-meta">
        <span class="label">12 · Transportation</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name vendor-name--tbc"><em>Quotes requested</em></h2>
        <p class="vendor-tbc-note">
          14-passenger sprinter for the bridal party (hotel → venue) and a
          vintage getaway sedan for the couple's exit.
        </p>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-pending">Pending quotes</span>
      </div>
    </article>

    <!-- 13 · Baker / Cake ─────────────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">13 · Baker / Cake</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>Pacific Pastries</em></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Contact</span>Lila Romero</li>
          <li><span class="contact-label">Phone</span><a href="tel:+18315551100">(831) 555-1100</a></li>
          <li><span class="contact-label">Email</span><a href="mailto:orders@pacificpastries.com">orders@pacificpastries.com</a></li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 14 · Hotel (Room Block) ──────────────────────────────────────── -->
    <article class="vendor is-booked">
      <div class="vendor-meta">
        <span class="label">14 · Hotel (Room Block)</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name"><em>La Playa Hotel</em><span class="vendor-note"> · venue room block</span></h2>
        <ul class="vendor-contact">
          <li><span class="contact-label">Block</span>40 rooms held · Oct 9–11</li>
          <li><span class="contact-label">Code</span>ALICIAJACK2026</li>
          <li><span class="contact-label">Cutoff</span>September 10, 2026</li>
        </ul>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-booked">Booked</span>
      </div>
    </article>

    <!-- 15 · Rehearsal Dinner Venue ───────────────────────────────────── -->
    <article class="vendor is-tbc">
      <div class="vendor-meta">
        <span class="label">15 · Rehearsal Dinner Venue</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name vendor-name--tbc"><em>Selecting now</em></h2>
        <p class="vendor-tbc-note">
          25 guests · coastal restaurant within 10 minutes of the venue.
          Looking at three candidates.
        </p>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-shortlist">Shortlisting</span>
      </div>
    </article>

    <!-- 16 · Honeymoon Hotel ──────────────────────────────────────────── -->
    <article class="vendor is-tbc">
      <div class="vendor-meta">
        <span class="label">16 · Honeymoon Hotel</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name vendor-name--tbc"><em>To be booked</em></h2>
        <p class="vendor-tbc-note">
          Couple's choice — Amalfi Coast, two-week stay. Booking direct
          through their travel agent.
        </p>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-pending">Couple's choice</span>
      </div>
    </article>

    <!-- 17 · Honeymoon Airline ────────────────────────────────────────── -->
    <article class="vendor is-tbc">
      <div class="vendor-meta">
        <span class="label">17 · Honeymoon Airline</span>
      </div>
      <div class="vendor-body">
        <h2 class="vendor-name vendor-name--tbc"><em>To be booked</em></h2>
        <p class="vendor-tbc-note">
          Travel agent handling — SFO → Naples direct. Targeting business
          class on the outbound.
        </p>
      </div>
      <div class="vendor-status">
        <span class="status-pill status-pending">Couple's choice</span>
      </div>
    </article>

  </section>


  <%- include('partials/footer', { couple }) %>

</body>
</html>
