<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { couple, title: 'Vendors', extraStyles: ['palette.css', 'guest-list.css', 'vendors.css'] }) %>
<body>

  <%- include('partials/topbar', { couple, currentPage }) %>

  <!-- ── Page header ─────────────────────────────────────────────────────── -->
  <section class="page-header">
    <span class="label page-eyebrow"><%= couple.display_name %></span>
    <h1 class="page-title">Vendors</h1>
    <p class="page-subtitle">
      The team behind <%= new Date(couple.wedding_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', timeZone: 'UTC' }) %>.
    </p>
  </section>

  <%
    const STATUS = {
      booked:    { label: 'Booked',         cls: 'status-booked' },
      shortlist: { label: 'Shortlisting',   cls: 'status-shortlist' },
      pending:   { label: 'Pending',        cls: 'status-pending' },
      na:        { label: 'N / A',          cls: 'status-na' },
    };
    function statusPill(s) { return STATUS[s] || { label: s || 'Pending', cls: 'status-pending' }; }
    function pad2(n) { return String(n).padStart(2, '0'); }
    const portalPfx = (typeof portalBase !== 'undefined' && portalBase) ? portalBase : `/p/${couple.slug}`;
    const stillSelecting = (counts.shortlist || 0) + (counts.pending || 0);
  %>

  <!-- ── Summary counts ──────────────────────────────────────────────────── -->
  <section class="section vendors-summary">
    <div class="summary-stats">
      <div class="stat">
        <div class="stat-label">Total</div>
        <div class="stat-number"><%= counts.total %></div>
      </div>
      <div class="stat">
        <div class="stat-label">Booked</div>
        <div class="stat-number stat-number--accent"><%= counts.booked || 0 %></div>
        <div class="stat-note">Contracts signed</div>
      </div>
      <div class="stat">
        <div class="stat-label">Still selecting</div>
        <div class="stat-number"><%= stillSelecting %></div>
      </div>
    </div>
  </section>

  <!-- ── Filter strip ─────────────────────────────────────────────────────── -->
  <% if (vendors.length > 0) { %>
  <div class="guest-filters" role="group" aria-label="Filter vendors">
    <span class="guest-filters-label">Filter</span>
    <div class="guest-filters-list">
      <button type="button" class="filter-chip is-active" data-filter="all">All</button>
      <% if (counts.booked) { %><button type="button" class="filter-chip" data-filter="booked">Booked</button><% } %>
      <% if (counts.shortlist) { %><button type="button" class="filter-chip" data-filter="shortlist">Shortlisting</button><% } %>
      <% if (counts.pending) { %><button type="button" class="filter-chip" data-filter="pending">TBC</button><% } %>
    </div>
  </div>
  <% } %>

  <!-- ── Vendor list ─────────────────────────────────────────────────────── -->
  <section class="section vendor-list">
    <% if (vendors.length === 0) { %>
      <p class="vendor-tbc-note" style="text-align:center; padding:4rem 0;">
        No vendors yet — Zoe will add them as bookings come in.
      </p>
    <% } %>

    <% vendors.forEach((v, i) => {
      const pill = statusPill(v.status);
      const isTbc = !v.display_name;
      const isBooked = v.status === 'booked';
      const stateClass = isBooked ? 'is-booked' : (v.status === 'na' ? 'is-na' : 'is-tbc');
      const showNote = isBooked && v.note && !v.note.startsWith('=== Outreach draft ===');
    %>
      <article class="vendor <%= stateClass %>" data-status="<%= v.status %>">
        <div class="vendor-meta">
          <span class="label"><%= pad2(v.position || i + 1) %> · <%= v.vendor_type %></span>
        </div>
        <div class="vendor-body">
          <% if (isTbc) { %>
            <h2 class="vendor-name vendor-name--tbc"><em>To be confirmed</em></h2>
            <% if (v.note) { %><p class="vendor-note"><%= v.note %></p><% } %>
          <% } else { %>
            <h2 class="vendor-name"><em><%= v.display_name %></em></h2>
            <ul class="vendor-contact">
              <% if (v.contact_name) { %>
                <li><span class="contact-label">Contact</span><%= v.contact_name %></li>
              <% } %>
              <% if (v.phone) { %>
                <li><span class="contact-label">Phone</span><a href="tel:<%= v.phone.replace(/[^+0-9]/g, '') %>"><%= v.phone %></a></li>
              <% } %>
              <% if (v.email) { %>
                <li><span class="contact-label">Email</span><a href="mailto:<%= v.email %>"><%= v.email %></a></li>
              <% } %>
              <% if (v.address) { %>
                <li><span class="contact-label">Address</span><%= v.address %></li>
              <% } %>
            </ul>
            <% if (showNote) { %><p class="vendor-note"><%= v.note %></p><% } %>
            <% if (isBooked && v.contract_url) { %>
              <a href="<%= portalPfx %>/vendors/<%= v.id %>/contract" target="_blank" rel="noopener" class="vendor-contract-link">View contract ↗</a>
            <% } %>
          <% } %>
        </div>
        <div class="vendor-status">
          <span class="status-pill <%= pill.cls %>"><%= pill.label %></span>
        </div>
      </article>
    <% }) %>
  </section>

  <%- include('partials/footer', { couple }) %>

  <script>
    (function () {
      const chips = document.querySelectorAll('.filter-chip[data-filter]');
      const cards = document.querySelectorAll('.vendor[data-status]');
      chips.forEach(chip => {
        chip.addEventListener('click', () => {
          const filter = chip.dataset.filter;
          chips.forEach(c => c.classList.remove('is-active'));
          chip.classList.add('is-active');
          cards.forEach(card => {
            card.hidden = filter !== 'all' && card.dataset.status !== filter;
          });
        });
      });
    })();
  </script>

</body>
</html>
