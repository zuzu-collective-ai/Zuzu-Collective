<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { couple, title: 'Design', extraStyles: ['palette.css'] }) %>
<body>

  <%- include('partials/topbar', { couple, currentPage }) %>

  <%
    // Map a material's swatch_kind to an inline `style` background.
    // Keeping the lookup here in the template (rather than in the route)
    // means new kinds only need a one-line addition, and the data layer
    // stays a flat enum string.
    function materialSwatchStyle(kind) {
      switch (kind) {
        case 'silver':    return 'background: linear-gradient(135deg, #d9d7d3 0%, #b8b6b2 50%, #d9d7d3 100%);';
        case 'gold':      return 'background: linear-gradient(135deg, #e6cf8a 0%, #b8983f 50%, #e6cf8a 100%);';
        case 'brass':     return 'background: linear-gradient(135deg, #d4b56a 0%, #9c7c2e 50%, #d4b56a 100%);';
        case 'white':     return 'background: #ffffff; border-color: var(--zz-finn-20);';
        case 'ivory':     return 'background: #efede1;';
        case 'clear':     return 'background: linear-gradient(135deg, #eee 0%, #ccc 50%, #eee 100%); opacity: 0.7;';
        case 'palette-1': return 'background: var(--couple-1);';
        case 'palette-2': return 'background: var(--couple-2);';
        case 'palette-3': return 'background: var(--couple-3); border-color: var(--zz-finn-20);';
        case 'palette-4': return 'background: var(--couple-4);';
        case 'palette-5': return 'background: var(--couple-5, var(--zz-finn-20));';
        default:          return 'background: var(--zz-finn-20);';
      }
    }
  %>

  <!-- ── Page header ─────────────────────────────────────────────────────── -->
  <section class="page-header">
    <span class="label page-eyebrow"><%= couple.display_name %></span>
    <h1 class="page-title">Design</h1>
    <% if (couple.design_subtitle) { %>
      <p class="page-subtitle"><%= couple.design_subtitle %></p>
    <% } %>
  </section>

  <!-- ── Primary palette — pulled from the couples row ────────────────────── -->
  <section class="section palette-primary">
    <div class="section-head">
      <span class="label">The palette</span>
      <h2 class="section-title"><%= couple.palette_color_5 ? 'Five colors, one mood.' : 'Four colors, one mood.' %></h2>
    </div>

    <div class="circle-swatches">
      <% [1, 2, 3, 4, 5].forEach(n => {
           if (n === 5 && !couple.palette_color_5) return;
      %>
        <div class="circle-swatch">
          <div class="circle-swatch-disc" style="background: <%= couple[`palette_color_${n}`] %>; <% if (n === 3) { %>border-color: var(--zz-finn-20);<% } %>"></div>
          <div class="circle-swatch-name"><%= couple[`palette_color_${n}_name`] || '' %></div>
          <div class="circle-swatch-hex"><%= couple[`palette_color_${n}`].toUpperCase() %></div>
        </div>
      <% }) %>
    </div>
  </section>

  <!-- ── Tone & Feeling ──────────────────────────────────────────────────── -->
  <% if (couple.tone_keywords || couple.tone_statement || couple.design_tone_title) { %>
    <section class="section tone-section">
      <div class="section-head">
        <span class="label">Tone &amp; Feeling</span>
        <% if (couple.design_tone_title) { %>
          <h2 class="section-title"><%= couple.design_tone_title %></h2>
        <% } %>
      </div>

      <% if (couple.tone_keywords)  { %><p class="tone-keywords"><%= couple.tone_keywords %></p><% } %>
      <% if (couple.tone_statement) { %><p class="tone-statement"><%= couple.tone_statement %></p><% } %>
    </section>
  <% } %>

  <!-- ── Inspiration intro ───────────────────────────────────────────────── -->
  <% if (galleries.length > 0) { %>
    <section class="section">
      <div class="section-head">
        <span class="label">Inspiration</span>
        <h2 class="section-title">Moments we're designing toward.</h2>
        <p class="section-description">
          <%= galleries.length %> categor<%= galleries.length === 1 ? 'y' : 'ies' %> of
          reference imagery — moments, moods, and details that capture what we're building toward.
        </p>
      </div>
    </section>
  <% } %>

  <% if (galleries.length > 0) { %>
  <div class="reorder-bar">
    <button id="gallery-edit-btn" class="reorder-btn">Edit order</button>
  </div>
  <% } %>
  <div id="gallery-list">
  <% galleries.forEach(g => {
       const tiles = tilesByGallery.get(g.id) || [];
  %>
    <section class="section" data-gallery="<%= g.id %>">
      <div class="section-head">
        <% if (g.eyebrow) { %><span class="label"><%= g.eyebrow %></span><% } %>
        <h2 class="section-title"><em><%= g.title %></em></h2>
        <% if (g.description) { %><p class="section-description"><%= g.description %></p><% } %>
      </div>

      <% if (tiles.length > 0) { %>
        <div class="inspiration-grid">
          <%
            // Auto-arrange: the hero tile gets the 2×2 spot; every fifth
            // tile after it gets a 1×2 "wide" slot for rhythm. Purely
            // index-based so Zoe never has to size a tile by hand.
            let nonHeroIndex = 0;
          %>
          <% tiles.forEach(tile => {
               let sizeClass = '';
               if (tile.is_hero) {
                 sizeClass = ' is-tall is-wide';
               } else {
                 if (nonHeroIndex % 5 === 4) sizeClass = ' is-wide';
                 nonHeroIndex++;
               }
          %>
            <div class="inspo-tile<%= sizeClass %><%= tile.image_url ? ' inspo-tile--photo' : '' %>"
                 <% if (tile.image_url) { %>style="background-image: url('<%= tile.image_url %>'); background-position: <%= tile.bg_position_x ?? 50 %>% <%= tile.bg_position_y ?? 50 %>%;"<% } %>>
              <% if (tile.image_url) { %><div class="inspo-tile-overlay"></div><% } %>
              <% if (tile.note) { %><div class="inspo-tile-note"><%= tile.note %></div><% } %>
              <span class="inspo-tile-label"><%= tile.label %></span>
              <span class="inspo-tile-title"><%= tile.title %></span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>
  <% }) %>
  </div>

  <!-- ── Materials ───────────────────────────────────────────────────────── -->
  <% if (materials.length > 0) { %>
    <section class="section">
      <div class="section-head">
        <span class="label">Materials</span>
        <% if (couple.design_materials_title) { %>
          <h2 class="section-title"><%= couple.design_materials_title %></h2>
        <% } %>
        <% if (couple.design_materials_note) { %>
          <p class="section-description"><%= couple.design_materials_note %></p>
        <% } %>
      </div>

      <div class="materials-grid">
        <% materials.forEach(m => { %>
          <div class="material">
            <% if (m.image_url) { %>
              <div class="material-swatch material-swatch--photo"
                   style="background-image: url('<%= m.image_url %>');"></div>
            <% } else { %>
              <div class="material-swatch" style="<%= materialSwatchStyle(m.swatch_kind) %>"></div>
            <% } %>
            <div class="material-title"><%= m.name %></div>
            <% if (m.detail) { %><div class="material-note"><%= m.detail %></div><% } %>
          </div>
        <% }) %>
      </div>
    </section>
  <% } %>

  <%- include('partials/footer', { couple }) %>

  <style>
    .reorder-bar { display:flex; justify-content:flex-end; padding:0 var(--space-lg) var(--space-sm); }
    .reorder-btn {
      font-family: var(--zz-mono); font-size: 0.65rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--zz-finn-60); background: none;
      border: 1px solid var(--zz-finn-20); padding: 0.45em 1.1em; cursor: pointer;
      transition: color 0.15s, border-color 0.15s; border-radius: 2px;
    }
    .reorder-btn:hover,
    .reorder-btn.is-active { color: var(--zz-finn); border-color: var(--zz-finn-60); }
    #gallery-list.is-editing [data-gallery] { outline: 1px dashed var(--zz-finn-20); outline-offset: -2px; }
    #gallery-list.is-editing .section-head { cursor: grab; user-select: none; }
    #gallery-list.is-editing .section-head:active { cursor: grabbing; }
    .reorder-ghost { opacity: 0.3; }
    .reorder-chosen { position: relative; z-index: 10; }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script>
  (function () {
    var KEY  = 'zuzu-design-order-<%= couple.slug %>';
    var list = document.getElementById('gallery-list');
    var btn  = document.getElementById('gallery-edit-btn');
    if (!list || !btn) return;
    var sortable = null;

    try {
      var saved = JSON.parse(localStorage.getItem(KEY));
      if (Array.isArray(saved)) {
        saved.forEach(function (id) {
          var el = list.querySelector('[data-gallery="' + id + '"]');
          if (el) list.appendChild(el);
        });
      }
    } catch (_) {}

    function saveOrder() {
      var order = Array.from(list.querySelectorAll('[data-gallery]')).map(function (el) { return el.dataset.gallery; });
      try { localStorage.setItem(KEY, JSON.stringify(order)); } catch (_) {}
    }

    btn.addEventListener('click', function () {
      var editing = list.classList.toggle('is-editing');
      btn.textContent = editing ? 'Done' : 'Edit order';
      btn.classList.toggle('is-active', editing);
      if (editing) {
        sortable = Sortable.create(list, {
          animation: 200,
          handle: '.section-head',
          ghostClass: 'reorder-ghost',
          chosenClass: 'reorder-chosen',
          onEnd: saveOrder,
        });
      } else if (sortable) {
        sortable.destroy();
        sortable = null;
      }
    });
  })();
  </script>

</body>
</html>
