<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { couple, title: 'Budget', extraStyles: ['palette.css', 'budget.css'] }) %>
<body>

  <%- include('partials/topbar', { couple, currentPage }) %>

  <%
    function fmtCurrency(cents) {
      const dollars = (cents || 0) / 100;
      const opts = Number.isInteger(dollars)
        ? { maximumFractionDigits: 0 }
        : { minimumFractionDigits: 2, maximumFractionDigits: 2 };
      return '$' + dollars.toLocaleString('en-US', opts);
    }
  %>

  <!-- ── Page header ─────────────────────────────────────────────────────── -->
  <section class="page-header">
    <span class="label page-eyebrow"><%= couple.display_name %></span>
    <h1 class="page-title">Budget</h1>
    <p class="page-subtitle">
      Where the investment goes. Tracks contracted totals, what's been paid,
      and the balance still due to each vendor.
    </p>
  </section>

  <!-- ── Summary stats ───────────────────────────────────────────────────── -->
  <section class="section summary">
    <div class="summary-stats">
      <div class="stat">
        <div class="stat-label">Total budget</div>
        <div class="stat-number"><%= fmtCurrency(summary.totalBudget) %></div>
        <div class="stat-note">Across <%= summary.categoryCount %> categor<%= summary.categoryCount === 1 ? 'y' : 'ies' %></div>
      </div>
      <div class="stat">
        <div class="stat-label">Contracted</div>
        <div class="stat-number stat-number--accent"><%= fmtCurrency(summary.totalContracted) %></div>
        <div class="stat-note"><%= summary.pctOfTotal %>% of budget committed</div>
      </div>
      <div class="stat">
        <div class="stat-label">Paid so far</div>
        <div class="stat-number"><%= fmtCurrency(summary.totalSpent) %></div>
      </div>
      <div class="stat">
        <div class="stat-label">Balance due</div>
        <div class="stat-number"><%= fmtCurrency(summary.totalOwed) %></div>
        <div class="stat-note">Remaining to vendors</div>
      </div>
    </div>
  </section>

  <!-- ── Payment schedule ──────────────────────────────────────────────── -->
  <% if (scheduledPayments.length > 0) { %>
    <section class="section payment-schedule">
      <div class="section-head">
        <span class="label">Payment schedule</span>
        <h2 class="section-title"><em>Upcoming due dates.</em></h2>
      </div>
      <ul class="payment-list">
        <% scheduledPayments.forEach(p => {
          const due = new Date(p.due_date);
          const fmtDue = due.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
          const isOverdue = p.daysUntil < 0;
          const isSoon    = !isOverdue && p.daysUntil <= 14;
          const urgency   = isOverdue ? 'overdue' : isSoon ? 'soon' : '';
          const balance   = Math.max(0, (p.amount_cents || 0) - (p.paid_cents || 0));
        %>
          <li class="payment-item<%= urgency ? ` payment-item--${urgency}` : '' %>">
            <div class="payment-date">
              <span class="payment-date-main"><%= fmtDue %></span>
              <% if (isOverdue) { %>
                <span class="payment-urgency">Overdue by <%= Math.abs(p.daysUntil) %> day<%= Math.abs(p.daysUntil) === 1 ? '' : 's' %></span>
              <% } else if (isSoon) { %>
                <span class="payment-urgency"><%= p.daysUntil === 0 ? 'Due today' : `${p.daysUntil} day${p.daysUntil === 1 ? '' : 's'} away` %></span>
              <% } %>
            </div>
            <div class="payment-desc">
              <em><%= p.name %></em>
              <% if (p.categoryTitle) { %><span class="payment-category"><%= p.categoryTitle %></span><% } %>
              <% if (p.vendor_label) { %><span class="payment-vendor"><%= p.vendor_label %></span><% } %>
            </div>
            <div class="payment-amount"><%= fmtCurrency(balance) %></div>
            <% if (p.status_label) { %>
              <div class="payment-status"><%= p.status_label %></div>
            <% } %>
          </li>
        <% }) %>
      </ul>
    </section>
  <% } %>

  <!-- ── Categories ──────────────────────────────────────────────────────── -->
  <% categories.forEach(cat => {
       const stats = categoryStats.get(cat.id) || { estimated: 0, contracted: 0, actual: 0, remaining: 0, pct: 0 };
       const lines = linesByCategory.get(cat.id) || [];
  %>
    <section class="section category">
      <div class="category-header">
        <div class="category-meta">
          <span class="label">Category <%= String(cat.category_number).padStart(2, '0') %></span>
          <h2 class="category-title">
            <%= cat.title %><% if (cat.title_emphasis) { %> <em><%= cat.title_emphasis %></em><% } %>
          </h2>
        </div>
        <div class="category-amount">
          <div class="amount-row">
            <div class="amount-cell"><span class="amount-label">Estimated</span><span class="amount-value"><%= fmtCurrency(stats.estimated) %></span></div>
            <div class="amount-cell"><span class="amount-label">Contracted</span><span class="amount-value"><%= fmtCurrency(stats.contracted) %></span></div>
            <div class="amount-cell"><span class="amount-label">Paid</span><span class="amount-value"><%= fmtCurrency(stats.actual) %></span></div>
            <div class="amount-cell"><span class="amount-label">Balance due</span><span class="amount-value"><%= fmtCurrency(stats.remaining) %></span></div>
          </div>
          <div class="progress-bar"><span style="width: <%= stats.pct %>%;"></span></div>
        </div>
      </div>

      <% if (lines.length > 0) { %>
        <ul class="line-items">
          <% lines.forEach(line => {
               const statusClass = `status-${(line.status_kind || 'upcoming').replace(/[^a-z]/g, '')}`;
               const balance = Math.max(0, (line.amount_cents || 0) - (line.paid_cents || 0));
          %>
            <li>
              <div class="line-name"><em><%= line.name %></em></div>
              <div class="line-vendor"><%= line.vendor_label || '' %></div>
              <div class="line-amount"><%= fmtCurrency(line.amount_cents) %></div>
              <div class="line-paid"><%= fmtCurrency(line.paid_cents) %> paid</div>
              <div class="line-balance<%= balance > 0 ? ' line-balance--due' : '' %>"><%= balance > 0 ? fmtCurrency(balance) + ' due' : '✓ Paid' %></div>
              <div class="line-status <%= statusClass %>"><%= line.status_label || '' %></div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  <% }) %>

  <!-- ── Footnote ────────────────────────────────────────────────────────── -->
  <% if (summary.totalBudget > 0) { %>
    <section class="section budget-footnote">
      <p>
        <em>Total budget: <%= fmtCurrency(summary.totalBudget) %>.</em>
        Contracted amounts reflect signed vendor totals; balance due updates
        as deposits and final payments are recorded.
      </p>
    </section>
  <% } %>


  <%- include('partials/footer', { couple }) %>

</body>
</html>
