<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { couple, title: 'Guest List, RSVP & Seating', extraStyles: ['palette.css', 'guest-list.css'] }) %>
<body>

  <%- include('partials/topbar', { couple, currentPage }) %>

  <!-- ── Page header ─────────────────────────────────────────────────────── -->
  <section class="page-header">
    <span class="label page-eyebrow"><%= couple.display_name %></span>
    <h1 class="page-title">Guest List, RSVP &amp; Seating</h1>
    <p class="page-subtitle">
      One source of truth for everyone invited — who said yes, who said no,
      who's still thinking, and where they'll sit. Households are the unit;
      seats are the count.
    </p>
  </section>

  <!-- ── Summary stats ───────────────────────────────────────────────────── -->
  <section class="section guest-summary">
    <div class="summary-stats">
      <div class="stat">
        <div class="stat-label">Invited</div>
        <div class="stat-number">124</div>
        <div class="stat-note">52 households</div>
      </div>
      <div class="stat">
        <div class="stat-label">Accepted</div>
        <div class="stat-number stat-number--accent">98</div>
        <div class="stat-note">79% of invites</div>
      </div>
      <div class="stat">
        <div class="stat-label">Awaiting</div>
        <div class="stat-number">12</div>
        <div class="stat-note">Follow up this week</div>
      </div>
      <div class="stat">
        <div class="stat-label">Declined</div>
        <div class="stat-number stat-number--decline">14</div>
        <div class="stat-note">5 households</div>
      </div>
      <div class="stat">
        <div class="stat-label">Seated</div>
        <div class="stat-number">84</div>
        <div class="stat-note">14 still to place</div>
      </div>
    </div>
  </section>

  <!-- ── Filter strip ─────────────────────────────────────────────────────── -->
  <div class="guest-filters" role="group" aria-label="Filter the guest list">
    <span class="guest-filters-label">Filter</span>
    <div class="guest-filters-list">
      <button type="button" class="filter-chip is-active">All</button>
      <button type="button" class="filter-chip">Bride's side</button>
      <button type="button" class="filter-chip">Groom's side</button>
      <button type="button" class="filter-chip">Both</button>
      <button type="button" class="filter-chip">Bridal party</button>
      <button type="button" class="filter-chip">Children</button>
    </div>
  </div>

