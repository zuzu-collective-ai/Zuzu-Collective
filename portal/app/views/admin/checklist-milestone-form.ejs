<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — ${milestone ? milestone.title : 'New milestone'}` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin/couples/<%= couple.id %>/checklist" class="admin-back">← <%= couple.display_name %> · checklist</a>
        <h1 class="admin-title">
          <%= milestone ? milestone.title : 'New milestone' %>
        </h1>
      </div>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'checklist' }) %>

    <%- include('partials/flash', { flash }) %>

    <% if (error) { %>
      <div class="admin-flash admin-flash--error" role="alert"><%= error %></div>
    <% } %>

    <form action="<%= formAction %>" method="post" class="admin-form">
      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Milestone</legend>

        <label class="admin-field">
          <span class="admin-field-label">Date label *</span>
          <input type="text" name="date_label" required
                 value="<%= milestone?.date_label || '' %>" placeholder="October 2025 · 12 Months Out">
          <span class="admin-field-help">Free text. Surfaces as the small mono eyebrow above the milestone title.</span>
        </label>

        <div class="admin-row" style="display: grid; grid-template-columns: 1fr 110px; gap: 1rem;">
          <label class="admin-field">
            <span class="admin-field-label">Title *</span>
            <input type="text" name="title" required
                   value="<%= milestone?.title || '' %>" placeholder="The foundation">
            <span class="admin-field-help">The italic editorial headline (e.g. "The foundation", "Filling in the canvas").</span>
          </label>
          <label class="admin-field">
            <span class="admin-field-label">Position</span>
            <input type="number" name="position" min="0"
                   value="<%= milestone?.position ?? suggestedPosition %>">
            <span class="admin-field-help">Order top-to-bottom.</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Tasks</legend>
        <p class="admin-fieldset-note">
          One row per checkbox. <em>Sub-text</em> is the small italic caption underneath the
          task name on the public page (booked vendor, follow-up reminder, etc.).
          A milestone with all tasks complete shows the "Complete" badge; the first
          milestone with any incomplete task gets the "You are here" marker.
        </p>

        <div id="task-rows" class="admin-task-rows">
          <%
            const initial = (tasks && tasks.length) ? tasks : [
              { name: '', sub_text: '', is_done: false, position: 1 },
            ];
          %>
          <% initial.forEach((t, i) => { %>
            <div class="admin-task-row" data-row>
              <input type="hidden" name="tasks[<%= i %>][id]" value="<%= t.id || '' %>">
              <label class="admin-field admin-field--inline admin-field--checkbox">
                <input type="checkbox" name="tasks[<%= i %>][is_done]" value="true" <%= t.is_done ? 'checked' : '' %>>
                <span class="admin-field-label">Done</span>
              </label>
              <label class="admin-field admin-field--inline">
                <span class="admin-field-label">Task</span>
                <input type="text" name="tasks[<%= i %>][name]" value="<%= t.name || '' %>" placeholder="Book the venue">
              </label>
              <label class="admin-field admin-field--inline">
                <span class="admin-field-label">Sub-text</span>
                <input type="text" name="tasks[<%= i %>][sub_text]" value="<%= t.sub_text || '' %>" placeholder="La Playa Hotel">
              </label>
              <button type="button" class="admin-btn admin-btn--ghost admin-btn--small" data-remove>Remove</button>
            </div>
          <% }) %>
        </div>

        <button type="button" id="add-task" class="admin-btn admin-btn--ghost">+ Add task</button>
      </fieldset>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">
          <%= milestone ? 'Save changes' : 'Add milestone' %>
        </button>
        <a href="/admin/couples/<%= couple.id %>/checklist" class="admin-btn admin-btn--ghost">Cancel</a>
      </div>
    </form>

    <% if (milestone) { %>
      <div class="admin-danger-zone">
        <h2 class="admin-legend">Danger zone</h2>
        <p>Remove this milestone and all of its tasks from <%= couple.display_name %>'s checklist.</p>
        <form action="/admin/couples/<%= couple.id %>/checklist/<%= milestone.id %>/delete" method="post"
              onsubmit="return confirm('Remove <%= milestone.title %>? This cannot be undone.');">
          <button type="submit" class="admin-btn admin-btn--danger">Remove milestone</button>
        </form>
      </div>
    <% } %>
  </main>

  <script>
    (function () {
      const container = document.getElementById('task-rows');
      const addBtn = document.getElementById('add-task');
      if (!container || !addBtn) return;

      function nextIndex() {
        return container.querySelectorAll('[data-row]').length;
      }

      function newRow() {
        const i = nextIndex();
        const row = document.createElement('div');
        row.className = 'admin-task-row';
        row.setAttribute('data-row', '');
        row.innerHTML = `
          <input type="hidden" name="tasks[${i}][id]" value="">
          <label class="admin-field admin-field--inline admin-field--checkbox">
            <input type="checkbox" name="tasks[${i}][is_done]" value="true">
            <span class="admin-field-label">Done</span>
          </label>
          <label class="admin-field admin-field--inline">
            <span class="admin-field-label">Task</span>
            <input type="text" name="tasks[${i}][name]" placeholder="Task name">
          </label>
          <label class="admin-field admin-field--inline">
            <span class="admin-field-label">Sub-text</span>
            <input type="text" name="tasks[${i}][sub_text]" placeholder="">
          </label>
          <button type="button" class="admin-btn admin-btn--ghost admin-btn--small" data-remove>Remove</button>
        `;
        container.appendChild(row);
      }

      addBtn.addEventListener('click', newRow);
      container.addEventListener('click', (e) => {
        if (e.target.matches('[data-remove]')) {
          const row = e.target.closest('[data-row]');
          if (row) row.remove();
        }
      });
    })();
  </script>
</body>
</html>
