<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — Design` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin" class="admin-back">← All couples</a>
        <h1 class="admin-title"><%= couple.display_name %></h1>
        <p class="admin-subtitle">
          <a href="/p/<%= couple.slug %>/design" target="_blank" rel="noopener">View live portal ↗</a>
        </p>
      </div>
      <a href="/admin/couples/<%= couple.id %>/design/galleries/new" class="admin-btn admin-btn--primary">+ Add gallery</a>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'design' }) %>

    <%- include('partials/flash', { flash }) %>

    <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0 0 1.5rem;">
      Palette, tone keywords &amp; statement, and editorial page copy live on the
      <a href="/admin/couples/<%= couple.id %>" class="admin-link">Basics tab</a>.
      This tab handles the inspiration galleries and the metals &amp; finishes grid.
    </p>

    <h2 class="admin-legend" style="margin-top: 0.5rem;">Inspiration galleries</h2>
    <% if (galleries.length === 0) { %>
      <p class="admin-empty">
        No galleries yet for <%= couple.display_name %>.
        <a href="/admin/couples/<%= couple.id %>/design/galleries/new">Add the first one</a>.
      </p>
    <% } else { %>
      <ul class="admin-list">
        <% galleries.forEach(g => { %>
          <li class="admin-list-item">
            <a href="/admin/couples/<%= couple.id %>/design/galleries/<%= g.id %>" class="admin-list-link">
              <div class="admin-list-name">
                <% if (g.eyebrow) { %><%= g.eyebrow %> · <% } %><em><%= g.title %></em>
              </div>
              <div class="admin-list-meta">
                <span><%= g.tile_count %> tile<%= g.tile_count === 1 ? '' : 's' %></span>
                <% if (g.hero_count > 0) { %><span><%= g.hero_count %> hero</span><% } %>
              </div>
            </a>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <h2 class="admin-legend" style="margin-top: 2.5rem;">Metals &amp; finishes</h2>
    <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0 0 1rem;">
      The 3-ish swatches under "Metals &amp; Finishes" on the live page.
      <a href="/admin/couples/<%= couple.id %>/design/materials" class="admin-link">Edit materials →</a>
    </p>
    <% if (materials.length > 0) { %>
      <ul class="admin-list">
        <% materials.forEach(m => { %>
          <li class="admin-list-item">
            <div class="admin-list-link">
              <div class="admin-list-name"><em><%= m.name %></em></div>
              <div class="admin-list-meta">
                <span><%= m.swatch_kind %></span>
                <% if (m.detail) { %><span><%= m.detail %></span><% } %>
              </div>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </main>

</body>
</html>
