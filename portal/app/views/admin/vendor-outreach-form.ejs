<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — AI vendor outreach` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin/couples/<%= couple.id %>/vendors" class="admin-back">← <%= couple.display_name %> · vendors</a>
        <h1 class="admin-title">AI vendor outreach</h1>
        <p class="admin-subtitle">Phase 4d · Claude Opus 4.7 · adaptive thinking</p>
      </div>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'vendors' }) %>

    <%- include('partials/flash', { flash }) %>

    <% if (error) { %>
      <div class="admin-flash admin-flash--error" role="alert"><%= error %></div>
    <% } %>

    <% if (!configured) { %>
      <div class="admin-flash admin-flash--info" style="margin-bottom: 1.5rem;">
        <strong>ANTHROPIC_API_KEY not set.</strong>
        Add it under Render → Environment to enable the generator.
      </div>
    <% } %>

    <% if (vendors.length === 0) { %>
      <p class="admin-empty">
        No pending or shortlisted vendors for <%= couple.display_name %>.
        Outreach drafts are only generated for vendors with status <em>Pending</em> or <em>Shortlisting</em>.
        <a href="/admin/couples/<%= couple.id %>/vendors">Back to vendors</a>.
      </p>
    <% } else { %>

    <!-- ── Input form ──────────────────────────────────────────────── -->
    <form action="<%= formAction %>" method="post" class="admin-form" style="margin-bottom: 2rem;">
      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Select vendors</legend>
        <p class="admin-fieldset-note">
          Claude drafts one intro email per selected vendor type, written in Zoe's voice.
          Drafts are previewed before saving to the vendor's note field.
        </p>

        <div class="admin-allocate-rows">
          <% vendors.forEach(v => {
               const checked = !submitted || (Array.isArray(submitted.vendor_ids)
                 ? submitted.vendor_ids.includes(v.id)
                 : submitted.vendor_ids === v.id);
          %>
            <div class="admin-allocate-row" style="align-items: center; padding: 0.75rem 0;">
              <label class="admin-field admin-field--inline admin-field--checkbox" style="margin: 0;">
                <input type="checkbox" name="vendor_ids" value="<%= v.id %>" <%= checked ? 'checked' : '' %>>
                <span class="admin-field-label" style="font-size: 0.9rem;">
                  <%= v.vendor_type %>
                  <% if (v.display_name) { %><em style="font-weight: 400;"> · <%= v.display_name %></em><% } %>
                </span>
              </label>
              <% if (v.note) { %>
                <div class="admin-allocate-row-rationale" style="padding-left: 1.75rem;"><em><%= v.note %></em></div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Additional context</legend>
        <label class="admin-field">
          <span class="admin-field-label">Brief</span>
          <textarea name="brief" rows="4"
            placeholder="e.g. Couple wants a photographer who does candid editorial shots, not posed. They loved the work of two specific photographers on Instagram. Budget is flexible for the right fit."><%= submitted?.brief || '' %></textarea>
          <span class="admin-field-help">
            Optional. Anything specific about what Zoe is looking for from these vendors.
            Wedding date and venue are pulled automatically from the couple record.
          </span>
        </label>
      </fieldset>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary" <% if (!configured) { %>disabled<% } %>>
          <%= proposal ? 'Regenerate drafts' : 'Generate outreach drafts' %>
        </button>
        <a href="/admin/couples/<%= couple.id %>/vendors" class="admin-btn admin-btn--ghost">Back to vendors</a>
      </div>
    </form>

    <!-- ── Proposal preview ───────────────────────────────────────── -->
    <% if (proposal) { %>
      <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0 0 1rem;">
        <%= proposal.rows.length %> draft<%= proposal.rows.length === 1 ? '' : 's' %> generated
        &nbsp;·&nbsp; tokens: <%= proposal.usage.input_tokens %> in, <%= proposal.usage.output_tokens %> out<% if (proposal.usage.cache_read_input_tokens > 0) { %>, <%= proposal.usage.cache_read_input_tokens %> cached<% } %>
        &nbsp;·&nbsp; Edit any field below, then save to vendor notes.
      </p>

      <form action="<%= formAction %>/apply" method="post" class="admin-form">
        <% proposal.rows.forEach((row, i) => { %>
          <fieldset class="admin-fieldset" style="margin-bottom: 1.5rem;">
            <legend class="admin-legend" style="display: flex; align-items: center; gap: 1rem;">
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem;">
                <input type="checkbox" name="save_<%= row.id %>" value="true" checked>
                Save to vendor note
              </label>
              <span><%= row.vendor_type %></span>
            </legend>

            <label class="admin-field">
              <span class="admin-field-label">Subject</span>
              <input type="text" name="drafts[<%= row.id %>][subject]"
                     value="<%= row.draft.subject %>">
            </label>

            <label class="admin-field">
              <span class="admin-field-label">Body</span>
              <textarea name="drafts[<%= row.id %>][body]" rows="12"><%= row.draft.body %></textarea>
            </label>
          </fieldset>
        <% }) %>

        <div class="admin-form-actions">
          <button type="submit" class="admin-btn admin-btn--primary">Save selected to vendor notes</button>
          <a href="/admin/couples/<%= couple.id %>/vendors" class="admin-btn admin-btn--ghost">Cancel</a>
        </div>
      </form>
    <% } %>

    <% } %>
  </main>

</body>
</html>
