<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — AI palette generator` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin/couples/<%= couple.id %>/design" class="admin-back">← <%= couple.display_name %> · design</a>
        <h1 class="admin-title">AI palette + tone generator</h1>
        <p class="admin-subtitle">Claude Opus 4.7 · adaptive thinking</p>
      </div>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'design' }) %>

    <%- include('partials/flash', { flash }) %>

    <% if (error) { %>
      <div class="admin-flash admin-flash--error" role="alert"><%= error %></div>
    <% } %>

    <% if (!configured) { %>
      <div class="admin-flash admin-flash--info" style="margin-bottom: 1.5rem;">
        <strong>ANTHROPIC_API_KEY not set.</strong>
        Add it under Render → Environment to enable the generator.
      </div>
    <% } %>

    <!-- ── Input form ─────────────────────────────────────────────────── -->
    <form action="<%= formAction %>" method="post" class="admin-form" style="margin-bottom: 2rem;">
      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Brief</legend>
        <p class="admin-fieldset-note">
          Claude proposes a 4-color palette, tone keywords, and a one-line tone statement
          for this couple. Venue and date are pulled from the Basics tab; the Brief field
          is where you describe the wedding's feel — the more specific, the better.
        </p>

        <label class="admin-field">
          <span class="admin-field-label">Season</span>
          <input type="text" name="season" value="<%= submitted?.season || '' %>" placeholder="Late October">
          <span class="admin-field-help">Optional. Helps Claude pick seasonally-appropriate colors.</span>
        </label>

        <label class="admin-field">
          <span class="admin-field-label">Brief</span>
          <textarea name="brief" rows="6" placeholder="e.g. Coastal California, candlelit reception under string lights, ivory and soft greens, never bright. Bride wants something timeless and editorial — not trendy. Groom is leaning toward darker accents (terracotta, garnet)."><%= submitted?.brief || '' %></textarea>
          <span class="admin-field-help">
            Free text. What feeling are they after? Specific colors they love or want to avoid?
            Anything that's already non-negotiable (florist's signature palette, venue's hard surfaces, etc.)?
          </span>
        </label>
      </fieldset>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary" <% if (!configured) { %>disabled<% } %>>
          <%= proposal ? 'Generate again' : 'Generate palette + tone' %>
        </button>
        <a href="/admin/couples/<%= couple.id %>/design" class="admin-btn admin-btn--ghost">Back to design</a>
      </div>
    </form>

    <!-- ── Proposal preview ──────────────────────────────────────────── -->
    <% if (proposal) { %>
      <div class="admin-flash admin-flash--info" style="margin-bottom: 1rem;">
        <strong>Proposal:</strong> <%= proposal.rationale_summary %>
      </div>

      <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0 0 1rem;">
        Tokens: <%= proposal.usage.input_tokens %> in, <%= proposal.usage.output_tokens %> out<% if (proposal.usage.cache_read_input_tokens > 0) { %>, <%= proposal.usage.cache_read_input_tokens %> cached<% } %>
      </p>

      <form action="<%= formAction %>/apply" method="post" class="admin-form">
        <fieldset class="admin-fieldset">
          <legend class="admin-legend">Proposed palette</legend>
          <p class="admin-fieldset-note">
            Tick a color to overwrite the corresponding palette slot on the couple. Hex and
            name apply as a pair — you'll never end up with a new hex next to an old name.
          </p>

          <div class="admin-palette-preview">
            <% [1, 2, 3, 4].forEach(n => {
                 const hex  = proposal[`palette_color_${n}`];
                 const name = proposal[`palette_color_${n}_name`];
                 const currentHex  = couple[`palette_color_${n}`];
                 const currentName = couple[`palette_color_${n}_name`];
                 const changed = (hex || '').toUpperCase() !== (currentHex || '').toUpperCase()
                              || name !== currentName;
            %>
              <div class="admin-palette-row">
                <input type="hidden" name="palette_color_<%= n %>"      value="<%= hex %>">
                <input type="hidden" name="palette_color_<%= n %>_name" value="<%= name %>">

                <label class="admin-field admin-field--inline admin-field--checkbox">
                  <input type="checkbox" name="apply_palette_<%= n %>" value="true" <%= changed ? 'checked' : '' %>>
                  <span class="admin-field-label">Apply</span>
                </label>

                <div class="admin-palette-disc" style="background: <%= hex %>;<% if (n === 3) { %> border: 1px solid var(--zz-finn-20);<% } %>"></div>

                <div class="admin-palette-meta">
                  <div class="admin-palette-name"><em><%= name %></em></div>
                  <div class="admin-palette-hex"><%= hex %></div>
                  <% if (changed && currentHex) { %>
                    <div class="admin-palette-current">
                      Current:
                      <span class="admin-palette-current-disc" style="background: <%= currentHex %>;<% if (n === 3) { %> border: 1px solid var(--zz-finn-20);<% } %>"></span>
                      <%= currentName || '—' %> (<%= (currentHex || '').toUpperCase() %>)
                    </div>
                  <% } else if (!changed) { %>
                    <div class="admin-palette-current">No change</div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </fieldset>

        <fieldset class="admin-fieldset">
          <legend class="admin-legend">Proposed tone</legend>

          <input type="hidden" name="tone_keywords"  value="<%= proposal.tone_keywords %>">
          <input type="hidden" name="tone_statement" value="<%= proposal.tone_statement %>">

          <%
            const toneChanged = proposal.tone_keywords !== couple.tone_keywords
                             || proposal.tone_statement !== couple.tone_statement;
          %>
          <label class="admin-field admin-field--inline admin-field--checkbox" style="margin-bottom: 1rem;">
            <input type="checkbox" name="apply_tone" value="true" <%= toneChanged ? 'checked' : '' %>>
            <span class="admin-field-label">Apply tone copy</span>
          </label>

          <p class="admin-palette-tone-keywords"><%= proposal.tone_keywords %></p>
          <p class="admin-palette-tone-statement"><em><%= proposal.tone_statement %></em></p>

          <% if (toneChanged) { %>
            <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0.5rem 0 0;">
              <strong>Current keywords:</strong> <%= couple.tone_keywords || '—' %><br>
              <strong>Current statement:</strong> <em><%= couple.tone_statement || '—' %></em>
            </p>
          <% } else { %>
            <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0.5rem 0 0;">No change from current tone.</p>
          <% } %>
        </fieldset>

        <div class="admin-form-actions">
          <button type="submit" class="admin-btn admin-btn--primary">Apply selected</button>
          <a href="/admin/couples/<%= couple.id %>/design" class="admin-btn admin-btn--ghost">Cancel</a>
        </div>
      </form>
    <% } %>

  </main>

</body>
</html>
