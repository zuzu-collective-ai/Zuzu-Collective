<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — AI checklist generator` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin/couples/<%= couple.id %>/checklist" class="admin-back">← <%= couple.display_name %> · checklist</a>
        <h1 class="admin-title">AI checklist generator</h1>
        <p class="admin-subtitle">Claude Opus 4.7 · adaptive thinking</p>
      </div>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'checklist' }) %>

    <%- include('partials/flash', { flash }) %>

    <% if (error) { %>
      <div class="admin-flash admin-flash--error" role="alert"><%= error %></div>
    <% } %>

    <% if (!configured) { %>
      <div class="admin-flash admin-flash--info" style="margin-bottom: 1.5rem;">
        <strong>ANTHROPIC_API_KEY not set.</strong>
        Add it under Render → Environment to enable the generator.
      </div>
    <% } %>

    <!-- ── Input form ──────────────────────────────────────────────── -->
    <form action="<%= formAction %>" method="post" class="admin-form" style="margin-bottom: 2rem;">
      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Inputs</legend>
        <p class="admin-fieldset-note">
          Claude generates an 11-milestone planning arc tailored to this couple's date, venue, and brief —
          with 45–55 tasks total. The proposal renders below for review before you apply it.
          <strong>Applying replaces all existing milestones and tasks for this couple.</strong>
        </p>

        <label class="admin-field">
          <span class="admin-field-label">Brief</span>
          <textarea name="brief" rows="5"
            placeholder="e.g. Full-service hotel so no rental coordination needed. Couple wants a longer engagement-party milestone. Small guest list (~60). Mother of the bride is heavily involved in florals decision."><%= submitted?.brief || '' %></textarea>
          <span class="admin-field-help">
            Free text — what's special about this couple, what they care about, any constraints.
            Wedding date and venue are pulled automatically from the couple record.
          </span>
        </label>
      </fieldset>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary" <% if (!configured) { %>disabled<% } %>>
          <%= proposal ? 'Regenerate checklist' : 'Generate checklist' %>
        </button>
        <a href="/admin/couples/<%= couple.id %>/checklist" class="admin-btn admin-btn--ghost">Back to checklist</a>
      </div>
    </form>

    <!-- ── Proposal preview ───────────────────────────────────────── -->
    <% if (proposal) { %>
      <div class="admin-flash admin-flash--info" style="margin-bottom: 1rem;">
        <strong>Proposal:</strong> <%= proposal.planning_summary %>
      </div>

      <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0 0 1rem;">
        <%= proposal.milestones.length %> milestones
        &nbsp;·&nbsp; <%= proposal.totalTasks %> tasks total
        &nbsp;·&nbsp; tokens: <%= proposal.usage.input_tokens %> in, <%= proposal.usage.output_tokens %> out<% if (proposal.usage.cache_read_input_tokens > 0) { %>, <%= proposal.usage.cache_read_input_tokens %> cached<% } %>
      </p>

      <form action="<%= formAction %>/apply" method="post" class="admin-form">
        <fieldset class="admin-fieldset">
          <legend class="admin-legend">Proposed checklist</legend>
          <p class="admin-fieldset-note">
            Review the milestones and tasks below. Edit any field directly before applying.
            Clicking <em>Apply to checklist</em> will <strong>delete all existing milestones and tasks</strong>
            for this couple and replace them with this arc.
          </p>

          <% proposal.milestones.forEach((m, mi) => { %>
            <div class="admin-allocate-row" style="margin-bottom: 1.5rem;">
              <input type="hidden" name="milestones[<%= mi %>][position]"   value="<%= m.position %>">

              <div class="admin-allocate-row-meta" style="margin-bottom: 0.5rem;">
                <div class="admin-allocate-row-title" style="font-size: 1rem;">
                  Milestone <%= m.position %>
                </div>
              </div>

              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem;">
                <label class="admin-field" style="margin: 0;">
                  <span class="admin-field-label">Date label</span>
                  <input type="text" name="milestones[<%= mi %>][date_label]" value="<%= m.date_label %>">
                </label>
                <label class="admin-field" style="margin: 0;">
                  <span class="admin-field-label">Title</span>
                  <input type="text" name="milestones[<%= mi %>][title]" value="<%= m.title %>">
                </label>
              </div>

              <div style="padding-left: 1rem; border-left: 2px solid var(--zz-finn-20);">
                <% m.tasks.forEach((t, ti) => { %>
                  <input type="hidden" name="milestones[<%= mi %>][tasks][<%= ti %>][position]" value="<%= t.position %>">
                  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem;">
                    <label class="admin-field" style="margin: 0;">
                      <% if (ti === 0) { %><span class="admin-field-label">Task</span><% } %>
                      <input type="text" name="milestones[<%= mi %>][tasks][<%= ti %>][name]"
                             value="<%= t.name %>" placeholder="Task name">
                    </label>
                    <label class="admin-field" style="margin: 0;">
                      <% if (ti === 0) { %><span class="admin-field-label">Note (optional)</span><% } %>
                      <input type="text" name="milestones[<%= mi %>][tasks][<%= ti %>][sub_text]"
                             value="<%= t.sub_text || '' %>" placeholder="Vendor · location, deadline note, etc.">
                    </label>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </fieldset>

        <div class="admin-form-actions">
          <button type="submit" class="admin-btn admin-btn--primary">Apply to checklist</button>
          <a href="/admin/couples/<%= couple.id %>/checklist" class="admin-btn admin-btn--ghost">Cancel</a>
        </div>
      </form>
    <% } %>

  </main>

</body>
</html>
