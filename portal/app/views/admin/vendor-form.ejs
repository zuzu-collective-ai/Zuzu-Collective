<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — ${vendor ? vendor.vendor_type : 'New vendor'}` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin/couples/<%= couple.id %>/vendors" class="admin-back">← <%= couple.display_name %> · vendors</a>
        <h1 class="admin-title">
          <%= vendor ? (vendor.display_name || vendor.vendor_type) : 'New vendor' %>
        </h1>
      </div>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'vendors' }) %>

    <%- include('partials/flash', { flash }) %>

    <% if (error) { %>
      <div class="admin-flash admin-flash--error" role="alert"><%= error %></div>
    <% } %>

    <% if (configured) { %>
    <div class="admin-fieldset" style="border: 1px dashed var(--zz-finn-20); padding: 1.25rem 1.5rem; margin-bottom: 2rem; border-radius: 2px;">
      <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
        <div>
          <div class="admin-legend" style="margin:0 0 0.25rem;">✦ Smart import</div>
          <div class="admin-field-help" style="margin:0;">Upload a photo of a business card, screenshot, or text file — Claude fills in the form.</div>
        </div>
        <div style="display:flex; align-items:center; gap:0.75rem;">
          <input type="file" id="vendor-import-file" accept="image/*,text/plain"
                 style="font-size:0.8rem; max-width:220px;">
          <button type="button" id="vendor-import-btn" class="admin-btn admin-btn--ghost">Extract</button>
        </div>
      </div>
      <div id="vendor-import-status" style="margin-top:0.75rem; font-size:0.8rem; color:var(--zz-tobacco); display:none;"></div>
    </div>
    <% } %>

    <form action="<%= formAction %>" method="post" class="admin-form">

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">The basics</legend>

        <label class="admin-field">
          <span class="admin-field-label">Vendor type *</span>
          <input type="text" name="vendor_type" list="vendor-types"
                 value="<%= vendor?.vendor_type || '' %>" required>
          <datalist id="vendor-types">
            <% vendorTypes.forEach(t => { %>
              <option value="<%= t %>"></option>
            <% }) %>
          </datalist>
          <span class="admin-field-help">e.g. Venue, Photographer, Florist. Free text — pick any of the suggestions or type your own.</span>
        </label>

        <label class="admin-field">
          <span class="admin-field-label">Display name</span>
          <input type="text" name="display_name" value="<%= vendor?.display_name || '' %>" placeholder="La Playa Hotel">
          <span class="admin-field-help">Leave blank for a TBC slot — fill in the note below to describe what's being looked for.</span>
        </label>

        <div class="admin-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <label class="admin-field">
            <span class="admin-field-label">Status *</span>
            <select name="status">
              <% const STATUS_LABELS = { booked: 'Booked', shortlist: 'Shortlisting', pending: 'Pending', na: 'N / A' }; %>
              <% statuses.forEach(s => { %>
                <option value="<%= s %>" <%= vendor?.status === s ? 'selected' : '' %>><%= STATUS_LABELS[s] || s %></option>
              <% }) %>
            </select>
          </label>

          <label class="admin-field">
            <span class="admin-field-label">Position</span>
            <input type="number" name="position" value="<%= vendor?.position ?? 0 %>" min="0">
            <span class="admin-field-help">Order on the public page (low to high).</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Contact</legend>

        <label class="admin-field">
          <span class="admin-field-label">Contact name</span>
          <input type="text" name="contact_name" value="<%= vendor?.contact_name || '' %>">
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Phone</span>
          <input type="text" name="phone" value="<%= vendor?.phone || '' %>" placeholder="(831) 624-6476">
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Email</span>
          <input type="email" name="email" value="<%= vendor?.email || '' %>">
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Address</span>
          <input type="text" name="address" value="<%= vendor?.address || '' %>">
        </label>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Contract</legend>
        <div class="admin-field">
          <span class="admin-field-label">Contract PDF</span>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <input type="url" name="contract_url" id="contract-url"
                   value="<%= vendor?.contract_url || '' %>"
                   placeholder="https://res.cloudinary.com/…" style="flex:1; min-width:0;">
            <input type="file" id="contract-file" accept=".pdf,application/pdf" style="display:none;">
            <button type="button" id="contract-upload-btn"
                    class="admin-btn admin-btn--ghost" style="white-space:nowrap; flex-shrink:0;">↑ Upload PDF</button>
          </div>
          <div id="contract-status" style="font-size:0.8rem; color:var(--zz-tobacco);"></div>
          <% if (vendor?.contract_url) { %>
            <a href="<%= vendor.contract_url.replace('/upload/', '/upload/fl_attachment/') %>" target="_blank" rel="noopener"
               class="admin-link" style="font-size:0.8rem; margin-top:0.25rem; display:inline-block;">↓ Download contract</a>
          <% } %>
        </div>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Note</legend>
        <label class="admin-field">
          <span class="admin-field-label">Free-text note</span>
          <textarea name="note" rows="6"><%= vendor?.note || '' %></textarea>
          <span class="admin-field-help">
            For booked vendors: a short qualifier ("in-house catering"). For TBC slots: what's being looked for.
            Notes are admin-only for pending/shortlisting vendors — only booked vendor notes appear on the client portal.
          </span>
        </label>
        <% if (vendor?.email && vendor?.note && vendor.note.startsWith('=== Outreach draft ===')) { %>
          <%
            const noteLines = vendor.note.split('\n');
            const subjectLine = noteLines[1] || '';
            const emailSubject = subjectLine.startsWith('Subject: ') ? subjectLine.slice(9) : '';
            const emailBody = noteLines.slice(3).join('\n').trim();
          %>
          <div style="margin-top: 0.75rem;">
            <a href="mailto:<%= vendor.email %>?subject=<%= encodeURIComponent(emailSubject) %>&body=<%= encodeURIComponent(emailBody) %>"
               class="admin-btn admin-btn--ghost" style="text-decoration: none;">
              ✉ Open in email client → <%= vendor.email %>
            </a>
            <p class="admin-field-help" style="margin-top: 0.4rem;">
              Opens your email app with subject and body pre-filled from the outreach draft above.
            </p>
          </div>
        <% } %>
      </fieldset>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">
          <%= vendor ? 'Save changes' : 'Add vendor' %>
        </button>
        <a href="/admin/couples/<%= couple.id %>/vendors" class="admin-btn admin-btn--ghost">Cancel</a>
      </div>
    </form>

    <% if (vendor) { %>
      <div class="admin-danger-zone">
        <h2 class="admin-legend">Danger zone</h2>
        <p>Permanently remove this vendor from <%= couple.display_name %>'s portal.</p>
        <form action="/admin/couples/<%= couple.id %>/vendors/<%= vendor.id %>/delete" method="post"
              onsubmit="return confirm('Remove <%= vendor.display_name || vendor.vendor_type %>? This cannot be undone.');">
          <button type="submit" class="admin-btn admin-btn--danger">Remove vendor</button>
        </form>
      </div>
    <% } %>
  </main>

  <% if (configured) { %>
  <script>
    (function () {
      const btn    = document.getElementById('vendor-import-btn');
      const input  = document.getElementById('vendor-import-file');
      const status = document.getElementById('vendor-import-status');
      const coupleId = '<%= couple.id %>';

      btn.addEventListener('click', async () => {
        if (!input.files[0]) { alert('Choose a file first.'); return; }
        btn.disabled = true;
        btn.textContent = 'Extracting…';
        status.style.display = 'block';
        status.textContent = 'Sending to Claude…';

        const fd = new FormData();
        fd.append('file', input.files[0]);

        try {
          const r = await fetch(`/admin/couples/${coupleId}/vendors/import`, {
            method: 'POST', body: fd,
          });
          const data = await r.json();
          if (!r.ok) throw new Error(data.error || 'Unknown error');

          // Fill in form fields
          const set = (name, val) => {
            const el = document.querySelector(`[name="${name}"]`);
            if (el && val) el.value = val;
          };
          set('display_name', data.display_name);
          set('contact_name', data.contact_name);
          set('email',        data.email);
          set('phone',        data.phone);
          set('address',      data.address);
          set('note',         data.note);

          // Set vendor_type select if it matches an option
          if (data.vendor_type) {
            const sel = document.querySelector('[name="vendor_type"]');
            if (sel) {
              const match = [...sel.options].find(o =>
                o.value.toLowerCase() === data.vendor_type.toLowerCase()
              );
              if (match) sel.value = match.value;
              else sel.value = data.vendor_type;
            }
          }

          status.textContent = '✓ Fields filled in — review and save.';
          status.style.color = 'var(--zz-ink)';
        } catch (err) {
          status.textContent = '✗ ' + err.message;
          status.style.color = 'red';
        } finally {
          btn.disabled = false;
          btn.textContent = 'Extract';
        }
      });
    })();
  </script>
  <% } %>

  <script src="/zz-upload.js"></script>
  <script>
    (function () {
      // Contract PDF upload
      const contractBtn    = document.getElementById('contract-upload-btn');
      const contractFile   = document.getElementById('contract-file');
      const contractUrl    = document.getElementById('contract-url');
      const contractStatus = document.getElementById('contract-status');
      if (contractBtn && contractFile) {
        contractBtn.addEventListener('click', () => contractFile.click());
        contractFile.addEventListener('change', async () => {
          if (!contractFile.files[0]) return;
          try { await window.zzCloudinary.upload(contractFile.files[0], contractUrl, contractStatus, 'raw'); }
          catch (_) {}
        });
      }

      // Phone auto-format on blur
      const phoneInput = document.querySelector('[name="phone"]');
      if (phoneInput) {
        phoneInput.addEventListener('blur', () => {
          const digits = phoneInput.value.replace(/\D/g, '');
          if (digits.length === 10) {
            phoneInput.value = `(${digits.slice(0,3)}) ${digits.slice(3,6)}-${digits.slice(6)}`;
          } else if (digits.length === 11 && digits[0] === '1') {
            phoneInput.value = `(${digits.slice(1,4)}) ${digits.slice(4,7)}-${digits.slice(7)}`;
          }
        });
      }
    })();
  </script>

</body>
</html>
