<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — Timeline` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin" class="admin-back">← All couples</a>
        <h1 class="admin-title"><%= couple.display_name %></h1>
        <p class="admin-subtitle">
          <a href="/p/<%= couple.slug %>/timeline" target="_blank" rel="noopener">View live portal ↗</a>
        </p>
      </div>
      <div style="display:flex; gap:0.5rem;">
        <a href="/admin/couples/<%= couple.id %>/timeline/generate" class="admin-btn admin-btn--ghost">✦ Generate timeline</a>
        <a href="/admin/couples/<%= couple.id %>/timeline/new" class="admin-btn admin-btn--primary">+ Add phase</a>
      </div>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'timeline' }) %>

    <%- include('partials/flash', { flash }) %>

    <% const totalEvents = phases.reduce((s, p) => s + (p.event_count || 0), 0); %>

    <% if (phases.length > 0) { %>
      <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0 0 1.5rem;">
        <%= phases.length %> phase<%= phases.length === 1 ? '' : 's' %>
        &nbsp;·&nbsp; <%= totalEvents %> event<%= totalEvents === 1 ? '' : 's' %>
        &nbsp;·&nbsp; <a href="/admin/couples/<%= couple.id %>" class="admin-link">Edit headline copy</a>
      </p>
    <% } %>

    <% if (phases.length === 0) { %>
      <p class="admin-empty">
        No timeline phases yet for <%= couple.display_name %>.
        <a href="/admin/couples/<%= couple.id %>/timeline/new">Add the first one</a>.
      </p>
    <% } else { %>
      <% const VARIANT = { standard: 'Standard', ceremony: 'Ceremony · accent', sendoff: 'Send-off · close' }; %>
      <p class="admin-drag-hint">Drag ≡ to reorder phases.</p>
      <ul class="admin-list" id="phase-list">
        <% phases.forEach(p => { %>
          <li class="admin-list-item" data-id="<%= p.id %>">
            <span class="admin-drag-handle" title="Drag to reorder">≡</span>
            <a href="/admin/couples/<%= couple.id %>/timeline/<%= p.id %>" class="admin-list-link">
              <div class="admin-list-name">
                <%= String(p.phase_number).padStart(2, '0') %> · <em><%= p.title %></em>
              </div>
              <div class="admin-list-meta">
                <% if (p.window_text) { %><span><%= p.window_text %></span><% } %>
                <span><%= p.event_count %> event<%= p.event_count === 1 ? '' : 's' %></span>
                <span><%= VARIANT[p.variant] || p.variant %></span>
              </div>
            </a>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </main>

  <style>
    .admin-drag-hint { font-size: 0.75rem; color: var(--admin-fg-muted); padding: 0 0 0.5rem; margin: 0 0 0.25rem; }
    .admin-list-item { display: flex; align-items: center; }
    .admin-drag-handle {
      flex-shrink: 0;
      padding: 0 0.75rem;
      cursor: grab;
      color: var(--admin-fg-muted);
      font-size: 1.1rem;
      user-select: none;
      opacity: 0.5;
      transition: opacity 0.15s;
    }
    .admin-drag-handle:hover { opacity: 1; }
    .admin-drag-handle:active { cursor: grabbing; }
    .admin-list-item.sortable-ghost { opacity: 0.3; }
    .admin-list-item.sortable-chosen { background: var(--admin-surface); }
    .admin-list-link { flex: 1; }
    #phase-save-status { font-size: 0.75rem; color: var(--admin-fg-muted); margin-left: 1rem; }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script>
  (function () {
    var list = document.getElementById('phase-list');
    if (!list) return;

    var status = document.createElement('span');
    status.id = 'phase-save-status';
    var header = document.querySelector('.admin-header');
    if (header) header.appendChild(status);

    Sortable.create(list, {
      handle: '.admin-drag-handle',
      animation: 150,
      ghostClass: 'sortable-ghost',
      chosenClass: 'sortable-chosen',
      onEnd: function () {
        var ids = Array.from(list.querySelectorAll('[data-id]')).map(function (el) { return el.dataset.id; });
        status.textContent = 'Saving…';
        fetch('/admin/couples/<%= couple.id %>/timeline/reorder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids: ids }),
        })
          .then(function (r) { return r.json(); })
          .then(function (d) { status.textContent = d.ok ? 'Saved ✓' : 'Error saving'; })
          .catch(function () { status.textContent = 'Error saving'; });
      },
    });
  })();
  </script>
</body>
</html>
