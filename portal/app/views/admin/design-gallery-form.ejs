<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — ${gallery ? gallery.title : 'New gallery'}` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin/couples/<%= couple.id %>/design" class="admin-back">← <%= couple.display_name %> · design</a>
        <h1 class="admin-title">
          <%= gallery ? gallery.title : 'New gallery' %>
        </h1>
      </div>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'design' }) %>

    <%- include('partials/flash', { flash }) %>

    <% if (error) { %>
      <div class="admin-flash admin-flash--error" role="alert"><%= error %></div>
    <% } %>

    <form action="<%= formAction %>" method="post" class="admin-form">
      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Gallery</legend>

        <div class="admin-row" style="display: grid; grid-template-columns: 1fr 2fr 110px; gap: 1rem;">
          <label class="admin-field">
            <span class="admin-field-label">Eyebrow</span>
            <input type="text" name="eyebrow" value="<%= gallery?.eyebrow || '' %>" placeholder="Ceremony">
          </label>
          <label class="admin-field">
            <span class="admin-field-label">Title *</span>
            <input type="text" name="title" required value="<%= gallery?.title || '' %>" placeholder="An olive-branch arch over the aisle.">
          </label>
          <label class="admin-field">
            <span class="admin-field-label">Position</span>
            <input type="number" name="position" min="0" value="<%= gallery?.position ?? suggestedPosition %>">
          </label>
        </div>

        <label class="admin-field">
          <span class="admin-field-label">Description</span>
          <textarea name="description" rows="3"><%= gallery?.description || '' %></textarea>
          <span class="admin-field-help">The one paragraph for this whole category — no per-photo caption needed.</span>
        </label>

        <label class="admin-field admin-field--inline admin-field--checkbox">
          <input type="checkbox" name="enabled" value="true" <%= (gallery?.enabled !== false) ? 'checked' : '' %>>
          <span class="admin-field-label">Show this category on the live portal</span>
        </label>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Photos</legend>
        <p class="admin-fieldset-note">
          Just add the inspo — no caption required. They're laid out automatically;
          the first photo becomes the hero unless you flag a different one.
        </p>

        <div id="tile-rows" class="admin-tile-rows">
          <%
            const initialTiles = (tiles && tiles.length) ? tiles : [
              { is_hero: false, position: 1 },
            ];
          %>
          <% initialTiles.forEach((t, i) => { %>
            <div class="admin-tile-row" data-row>
              <input type="hidden" name="tiles[<%= i %>][id]" value="<%= t.id || '' %>">
              <label class="admin-field admin-field--inline admin-field--checkbox">
                <input type="checkbox" name="tiles[<%= i %>][is_hero]" value="true" <%= t.is_hero ? 'checked' : '' %>>
                <span class="admin-field-label">Hero</span>
              </label>
              <div class="admin-field admin-field--inline" style="flex: 1.5;">
                <span class="admin-field-label">Image URL</span>
                <input type="url" name="tiles[<%= i %>][image_url]" value="<%= t.image_url || '' %>" placeholder="https://res.cloudinary.com/…" data-img-url>
                <div style="display:flex; gap:0.3rem; align-items:center;">
                  <button type="button" class="admin-btn admin-btn--ghost admin-btn--small"
                          style="padding:0.3rem 0.5rem;" data-cld-btn>↑</button>
                  <span data-cld-status style="font-size:0.7rem; color:var(--zz-tobacco);"></span>
                </div>
                <input type="file" accept="image/*" style="display:none;" data-cld-file>
                <input type="hidden" name="tiles[<%= i %>][bg_position_x]" value="<%= t.bg_position_x ?? 50 %>" data-bg-x>
                <input type="hidden" name="tiles[<%= i %>][bg_position_y]" value="<%= t.bg_position_y ?? 50 %>" data-bg-y>
                <div data-drag-wrap style="display:<%= t.image_url ? 'block' : 'none' %>; margin-top:0.4rem;">
                  <div data-drag-preview style="
                    width:100%; aspect-ratio:1; max-width:120px;
                    background-size:cover;
                    background-image:<%= t.image_url ? `url('${t.image_url}')` : 'none' %>;
                    background-position:<%= t.bg_position_x ?? 50 %>% <%= t.bg_position_y ?? 50 %>%;
                    border:1px solid var(--zz-finn-20); border-radius:2px;
                    cursor:grab; user-select:none; touch-action:none;"></div>
                  <span style="font-size:0.7rem; color:var(--zz-finn-60);">drag to reposition</span>
                </div>
              </div>
              <button type="button" class="admin-btn admin-btn--ghost admin-btn--small" data-remove>Remove</button>
            </div>
          <% }) %>
        </div>

        <button type="button" id="add-tile" class="admin-btn admin-btn--ghost">+ Add photo</button>
      </fieldset>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">
          <%= gallery ? 'Save changes' : 'Add gallery' %>
        </button>
        <a href="/admin/couples/<%= couple.id %>/design" class="admin-btn admin-btn--ghost">Cancel</a>
      </div>
    </form>

    <% if (gallery) { %>
      <div class="admin-danger-zone">
        <h2 class="admin-legend">Danger zone</h2>
        <p>Remove this gallery and all of its tiles from <%= couple.display_name %>'s design page.</p>
        <form action="/admin/couples/<%= couple.id %>/design/galleries/<%= gallery.id %>/delete" method="post"
              onsubmit="return confirm('Remove <%= gallery.title %>? This cannot be undone.');">
          <button type="submit" class="admin-btn admin-btn--danger">Remove gallery</button>
        </form>
      </div>
    <% } %>
  </main>

  <script src="/zz-upload.js"></script>
  <script>
    (function () {
      const container = document.getElementById('tile-rows');
      const addBtn = document.getElementById('add-tile');
      if (!container || !addBtn) return;

      function nextIndex() { return container.querySelectorAll('[data-row]').length; }

      addBtn.addEventListener('click', () => {
        const i = nextIndex();
        const html = `
          <div class="admin-tile-row" data-row>
            <input type="hidden" name="tiles[${i}][id]" value="">
            <label class="admin-field admin-field--inline admin-field--checkbox">
              <input type="checkbox" name="tiles[${i}][is_hero]" value="true">
              <span class="admin-field-label">Hero</span>
            </label>
            <div class="admin-field admin-field--inline" style="flex: 1.5;">
              <span class="admin-field-label">Image URL</span>
              <input type="url" name="tiles[${i}][image_url]" placeholder="https://res.cloudinary.com/…" data-img-url>
              <div style="display:flex; gap:0.3rem; align-items:center;">
                <button type="button" class="admin-btn admin-btn--ghost admin-btn--small"
                        style="padding:0.3rem 0.5rem;" data-cld-btn>↑</button>
                <span data-cld-status style="font-size:0.7rem; color:var(--zz-tobacco);"></span>
              </div>
              <input type="file" accept="image/*" style="display:none;" data-cld-file>
              <input type="hidden" name="tiles[${i}][bg_position_x]" value="50" data-bg-x>
              <input type="hidden" name="tiles[${i}][bg_position_y]" value="50" data-bg-y>
              <div data-drag-wrap style="display:none; margin-top:0.4rem;">
                <div data-drag-preview style="
                  width:100%; aspect-ratio:1; max-width:120px;
                  background-size:cover; background-position:50% 50%;
                  border:1px solid var(--zz-finn-20); border-radius:2px;
                  cursor:grab; user-select:none; touch-action:none;"></div>
                <span style="font-size:0.7rem; color:var(--zz-finn-60);">drag to reposition</span>
              </div>
            </div>
            <button type="button" class="admin-btn admin-btn--ghost admin-btn--small" data-remove>Remove</button>
          </div>
        `;
        container.insertAdjacentHTML('beforeend', html);
      });

      container.addEventListener('click', (e) => {
        if (e.target.matches('[data-remove]')) {
          const row = e.target.closest('[data-row]');
          if (row) row.remove();
        }
        if (e.target.matches('[data-cld-btn]')) {
          const row = e.target.closest('[data-row]');
          if (row) row.querySelector('[data-cld-file]').click();
        }
      });

      container.addEventListener('change', async (e) => {
        if (!e.target.matches('[data-cld-file]')) return;
        const file = e.target.files[0];
        if (!file) return;
        const row = e.target.closest('[data-row]');
        const urlInput  = row.querySelector('input[type="url"]');
        const statusEl  = row.querySelector('[data-cld-status]');
        const btn       = row.querySelector('[data-cld-btn]');
        if (btn) btn.disabled = true;
        try {
          await window.zzCloudinary.upload(file, urlInput, statusEl);
          if (statusEl) { statusEl.textContent = '✓ Uploaded'; setTimeout(() => { statusEl.textContent = ''; }, 3000); }
        } catch (_) {}
        if (btn) btn.disabled = false;
        e.target.value = '';
        // Show drag preview after upload
        const wrap = row.querySelector('[data-drag-wrap]');
        const preview = row.querySelector('[data-drag-preview]');
        if (wrap && preview && urlInput.value) {
          preview.style.backgroundImage = `url('${urlInput.value}')`;
          wrap.style.display = 'block';
        }
      });

      // ── Drag-to-reposition ──────────────────────────────────────────
      function initDrag(row) {
        const urlInput = row.querySelector('[data-img-url]');
        const preview  = row.querySelector('[data-drag-preview]');
        const wrap     = row.querySelector('[data-drag-wrap]');
        const xInput   = row.querySelector('[data-bg-x]');
        const yInput   = row.querySelector('[data-bg-y]');
        if (!preview || !xInput || !yInput) return;

        function syncPreview(url) {
          if (url && /^https?:\/\//.test(url)) {
            preview.style.backgroundImage = `url('${url}')`;
            wrap.style.display = 'block';
          } else {
            wrap.style.display = 'none';
          }
        }
        if (urlInput) {
          syncPreview(urlInput.value);
          urlInput.addEventListener('input', () => syncPreview(urlInput.value));
        }

        let dragging = false, startX, startY, startBgX, startBgY;

        function onStart(clientX, clientY) {
          dragging = true;
          startX = clientX; startY = clientY;
          startBgX = parseFloat(xInput.value) || 50;
          startBgY = parseFloat(yInput.value) || 50;
          preview.style.cursor = 'grabbing';
        }
        function onMove(clientX, clientY) {
          if (!dragging) return;
          const rect = preview.getBoundingClientRect();
          const newX = Math.max(0, Math.min(100, startBgX - (clientX - startX) / rect.width * 100));
          const newY = Math.max(0, Math.min(100, startBgY - (clientY - startY) / rect.height * 100));
          xInput.value = Math.round(newX);
          yInput.value = Math.round(newY);
          preview.style.backgroundPosition = `${newX}% ${newY}%`;
        }
        function onEnd() { dragging = false; preview.style.cursor = 'grab'; }

        preview.addEventListener('mousedown',  e => { onStart(e.clientX, e.clientY); e.preventDefault(); });
        preview.addEventListener('touchstart', e => { onStart(e.touches[0].clientX, e.touches[0].clientY); }, { passive: true });
        document.addEventListener('mousemove',  e => onMove(e.clientX, e.clientY));
        document.addEventListener('touchmove',  e => { if (dragging) onMove(e.touches[0].clientX, e.touches[0].clientY); }, { passive: true });
        document.addEventListener('mouseup',   onEnd);
        document.addEventListener('touchend',  onEnd);
      }

      // Init drag on all existing rows and new ones
      container.querySelectorAll('[data-row]').forEach(initDrag);
      const _origAddTile = addBtn.onclick;
      addBtn.addEventListener('click', () => {
        const rows = container.querySelectorAll('[data-row]');
        initDrag(rows[rows.length - 1]);
      });
    })();
  </script>
</body>
</html>
