<%#
  Used for both new and edit. `couple` is null in new mode, otherwise
  the row from the DB. `formAction` is the POST URL.
%>
<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: couple?.display_name ? `Edit ${couple.display_name}` : 'New couple' }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin" class="admin-back">← All couples</a>
        <h1 class="admin-title"><%= couple?.display_name || 'New couple' %></h1>
        <% if (couple?.slug) { %>
          <p class="admin-subtitle">
            <a href="/p/<%= couple.slug %>" target="_blank" rel="noopener">View live portal ↗</a>
          </p>
        <% } %>
      </div>
    </header>

    <% if (couple) { %>
      <%- include('partials/couple-tabs', { couple, currentTab: 'basics' }) %>
    <% } %>

    <%- include('partials/flash', { flash }) %>

    <% if (error) { %>
      <div class="admin-flash admin-flash--error" role="alert"><%= error %></div>
    <% } %>

    <% if (couple && activity) { %>
      <%
        function timeAgo(d) {
          if (!d) return null;
          const secs = Math.floor((Date.now() - new Date(d)) / 1000);
          if (secs < 60)    return 'just now';
          if (secs < 3600)  return `${Math.floor(secs / 60)}m ago`;
          if (secs < 86400) return `${Math.floor(secs / 3600)}h ago`;
          return `${Math.floor(secs / 86400)}d ago`;
        }
      %>
      <div class="admin-activity-bar">
        <span>Portal activity (7 days)</span>
        <span><strong><%= activity.views_7d %></strong> view<%= activity.views_7d === 1 ? '' : 's' %></span>
        <span><strong><%= activity.unique_7d %></strong> unique visitor<%= activity.unique_7d === 1 ? '' : 's' %></span>
        <span><strong><%= activity.views_24h %></strong> in last 24 h</span>
        <% if (activity.last_viewed_at) { %>
          <span>Last seen <strong><%= timeAgo(activity.last_viewed_at) %></strong></span>
        <% } else { %>
          <span style="opacity: 0.6;">Not yet viewed</span>
        <% } %>
      </div>
    <% } %>

    <form action="<%= formAction %>" method="post" class="admin-form">

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">The basics</legend>

        <label class="admin-field">
          <span class="admin-field-label">Display name *</span>
          <input type="text" name="display_name" value="<%= couple?.display_name || '' %>" required>
          <span class="admin-field-help">How the couple is named in headlines. e.g. "Alicia &amp; Jack".</span>
        </label>

        <label class="admin-field">
          <span class="admin-field-label">Slug *</span>
          <input type="text" name="slug" value="<%= couple?.slug || '' %>" required pattern="[a-z0-9\-]+" placeholder="alicia-and-jack-2026">
          <span class="admin-field-help">URL segment. Lowercase, dashes only. The portal lives at <code>/p/&lt;slug&gt;</code>.</span>
        </label>

        <label class="admin-field">
          <span class="admin-field-label">Wedding date *</span>
          <input type="date" name="wedding_date" value="<%= couple?.wedding_date ? new Date(couple.wedding_date).toISOString().slice(0, 10) : '' %>" required>
        </label>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Budget headline</legend>
        <label class="admin-field">
          <span class="admin-field-label">Total budget (USD)</span>
          <input type="text" name="budget_total_cents"
                 value="<%= couple?.budget_total_cents ? (couple.budget_total_cents / 100).toFixed(couple.budget_total_cents % 100 === 0 ? 0 : 2) : '' %>"
                 placeholder="120000"
                 inputmode="decimal">
          <span class="admin-field-help">
            The headline number on the budget page. Enter dollars — commas and a "$" are fine.
            Per-category targets and per-line amounts live on the budget tab.
          </span>
        </label>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Timeline headline</legend>
        <p class="admin-fieldset-note">
          The four small stat-notes at the top of <code>/timeline</code>. The Date stat is
          computed from the wedding date; the Events count is computed live. These four
          fields are editorial flavor copy alongside them. Leave any field blank to hide
          its column.
        </p>
        <div class="admin-row" style="display: grid; grid-template-columns: 110px 1fr; gap: 1rem;">
          <label class="admin-field">
            <span class="admin-field-label">Ceremony time</span>
            <input type="text" name="timeline_ceremony_time" value="<%= couple?.timeline_ceremony_time || '' %>" placeholder="4:00">
          </label>
          <label class="admin-field">
            <span class="admin-field-label">Ceremony note</span>
            <input type="text" name="timeline_ceremony_note" value="<%= couple?.timeline_ceremony_note || '' %>" placeholder="Sunset 6:32 PM">
          </label>
        </div>
        <div class="admin-row" style="display: grid; grid-template-columns: 110px 1fr; gap: 1rem;">
          <label class="admin-field">
            <span class="admin-field-label">Last call time</span>
            <input type="text" name="timeline_lastcall_time" value="<%= couple?.timeline_lastcall_time || '' %>" placeholder="10:30">
          </label>
          <label class="admin-field">
            <span class="admin-field-label">Last call note</span>
            <input type="text" name="timeline_lastcall_note" value="<%= couple?.timeline_lastcall_note || '' %>" placeholder="Sparkler send-off">
          </label>
        </div>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Floor plan headline</legend>
        <p class="admin-fieldset-note">
          The "Walkthrough" stat-note at the top of <code>/floor-plan</code>. Venue, Spaces,
          and Footprint are derived from the venue fields and floorplan rows.
        </p>
        <div class="admin-row" style="display: grid; grid-template-columns: 110px 1fr; gap: 1rem;">
          <label class="admin-field">
            <span class="admin-field-label">Walkthrough date</span>
            <input type="text" name="floorplan_walkthrough_date" value="<%= couple?.floorplan_walkthrough_date || '' %>" placeholder="9.26">
          </label>
          <label class="admin-field">
            <span class="admin-field-label">Walkthrough note</span>
            <input type="text" name="floorplan_walkthrough_note" value="<%= couple?.floorplan_walkthrough_note || '' %>" placeholder="Final at 10 AM">
          </label>
        </div>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Design page copy</legend>
        <p class="admin-fieldset-note">
          Editorial copy on <code>/design</code>. The palette and tone keywords above
          drive the rest of the page; inspiration galleries and materials live on the
          Design tab.
        </p>
        <label class="admin-field">
          <span class="admin-field-label">Page subtitle</span>
          <textarea name="design_subtitle" rows="2"><%= couple?.design_subtitle || '' %></textarea>
          <span class="admin-field-help">The long paragraph under the H1 on the design page.</span>
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Tone section title</span>
          <input type="text" name="design_tone_title" value="<%= couple?.design_tone_title || '' %>" placeholder="Intimate and considered. Nothing overdone.">
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Materials section title</span>
          <input type="text" name="design_materials_title" value="<%= couple?.design_materials_title || '' %>" placeholder="Polished silver. Matte white. Clear glass.">
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Materials section note</span>
          <input type="text" name="design_materials_note" value="<%= couple?.design_materials_note || '' %>" placeholder="All warmth reliant on candlelight.">
        </label>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Venue</legend>
        <label class="admin-field">
          <span class="admin-field-label">Venue name</span>
          <input type="text" name="venue_name" value="<%= couple?.venue_name || '' %>" placeholder="La Playa">
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Venue location</span>
          <input type="text" name="venue_location" value="<%= couple?.venue_location || '' %>" placeholder="Carmel-by-the-Sea">
        </label>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Palette</legend>
        <p class="admin-fieldset-note">Four colors plus optional friendly names. The portal recolors itself wherever <code>--couple-1..4</code> is referenced.</p>

        <% [1, 2, 3, 4].forEach(n => {
             const colorVal = couple?.[`palette_color_${n}`] || (n === 1 ? '#EFEDE1' : n === 2 ? '#64690C' : n === 3 ? '#FFFFFF' : '#F5F0E4');
        %>
          <div class="admin-row admin-row--palette">
            <label class="admin-field admin-field--swatch">
              <span class="admin-field-label">Color <%= n %></span>
              <span class="admin-swatch-row">
                <input type="color" id="color-pick-<%= n %>" value="<%= colorVal %>"
                       oninput="document.getElementById('color-hex-<%= n %>').value=this.value">
                <input type="text" id="color-hex-<%= n %>" name="palette_color_<%= n %>"
                       value="<%= colorVal %>" maxlength="7" class="admin-swatch-hex"
                       placeholder="#EFEDE1"
                       oninput="(function(el){var v=el.value.trim();if(!v.startsWith('#'))v='#'+v;if(/^#[0-9a-fA-F]{6}$/.test(v)){el.value=v;document.getElementById('color-pick-<%= n %>').value=v;}})(this)">
                <input type="text" name="palette_color_<%= n %>_name" value="<%= couple?.[`palette_color_${n}_name`] || '' %>" placeholder="Ivory" class="admin-swatch-name">
              </span>
            </label>
          </div>
        <% }) %>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Tone &amp; feeling</legend>
        <label class="admin-field">
          <span class="admin-field-label">Keywords</span>
          <input type="text" name="tone_keywords" value="<%= couple?.tone_keywords || '' %>" placeholder="Elegant · Coastal · Candlelit · Californian · Timeless · Intentional">
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Statement</span>
          <input type="text" name="tone_statement" value="<%= couple?.tone_statement || '' %>" placeholder="All warmth reliant on candlelight.">
        </label>
      </fieldset>

      <fieldset class="admin-fieldset">
        <legend class="admin-legend">Landing copy</legend>
        <div class="admin-field">
          <span class="admin-field-label">Hero photo URL</span>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <input type="url" name="hero_photo_url" id="hero-photo-url"
                   value="<%= couple?.hero_photo_url || '' %>"
                   placeholder="https://res.cloudinary.com/…" style="flex:1; min-width:0;">
            <input type="file" id="hero-photo-file" accept="image/*" style="display:none;">
            <button type="button" id="hero-photo-upload-btn"
                    class="admin-btn admin-btn--ghost" style="white-space:nowrap; flex-shrink:0;">↑ Upload</button>
          </div>
          <div id="hero-photo-status" style="font-size:0.8rem; color:var(--zz-tobacco);"></div>
          <img id="hero-photo-preview" src="<%= couple?.hero_photo_url || '' %>"
               style="max-height:80px; border-radius:2px; margin-top:0.25rem; display:<%= couple?.hero_photo_url ? 'block' : 'none' %>;">
          <span class="admin-field-help">
            Full-bleed hero photo. Upload a file or paste a URL.
            Leave blank to show the palette gradient.
          </span>
        </div>
        <label class="admin-field">
          <span class="admin-field-label">Hero text color</span>
          <select name="hero_text_color">
            <option value="dark" <%= (couple?.hero_text_color || 'dark') === 'dark' ? 'selected' : '' %>>Dark plum — for light photos</option>
            <option value="light" <%= couple?.hero_text_color === 'light' ? 'selected' : '' %>>Cream — for dark photos</option>
          </select>
          <span class="admin-field-help">Switch to Cream if the hero text disappears against a dark photo.</span>
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Hero subtitle</span>
          <input type="text" name="hero_subtitle" value="<%= couple?.hero_subtitle || 'Wedding Portal' %>">
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Intro paragraph</span>
          <textarea name="intro_text" rows="3"><%= couple?.intro_text || '' %></textarea>
          <span class="admin-field-help">Long-form copy on the home page just below the hero.</span>
        </label>
        <label class="admin-field">
          <span class="admin-field-label">Intro tagline</span>
          <input type="text" name="intro_tagline" value="<%= couple?.intro_tagline || 'escape the mundane.' %>">
        </label>
      </fieldset>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">
          <%= couple ? 'Save changes' : 'Create couple' %>
        </button>
        <% if (couple) { %>
          <a href="/admin" class="admin-btn admin-btn--ghost">Cancel</a>
        <% } %>
      </div>
    </form>

    <% if (couple) { %>
      <div class="admin-danger-zone">
        <h2 class="admin-legend">Danger zone</h2>
        <p>Permanently delete this couple's portal and all related data.</p>
        <form action="/admin/couples/<%= couple.id %>/delete" method="post"
              onsubmit="return confirm('Delete <%= couple.display_name %>? This cannot be undone.');">
          <button type="submit" class="admin-btn admin-btn--danger">Delete couple</button>
        </form>
      </div>
    <% } %>
  </main>

  <script src="/zz-upload.js"></script>
  <script>
    (function () {
      const urlInput  = document.getElementById('hero-photo-url');
      const fileInput = document.getElementById('hero-photo-file');
      const uploadBtn = document.getElementById('hero-photo-upload-btn');
      const statusEl  = document.getElementById('hero-photo-status');
      const preview   = document.getElementById('hero-photo-preview');
      if (!uploadBtn) return;

      uploadBtn.addEventListener('click', () => fileInput.click());

      fileInput.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        uploadBtn.disabled = true;
        try {
          await window.zzCloudinary.upload(file, urlInput, statusEl);
          if (urlInput.value) { preview.src = urlInput.value; preview.style.display = 'block'; }
        } catch (_) {}
        uploadBtn.disabled = false;
        fileInput.value = '';
      });

      urlInput.addEventListener('input', () => {
        if (/^https?:\/\//.test(urlInput.value)) {
          preview.src = urlInput.value;
          preview.style.display = 'block';
        } else {
          preview.style.display = 'none';
        }
      });

      // Auto-format tone keywords to " · " on blur
      const kwInput = document.querySelector('[name="tone_keywords"]');
      if (kwInput) {
        kwInput.addEventListener('blur', () => {
          const raw = kwInput.value.trim();
          if (!raw) return;
          const words = raw.split(/\s*[,\-·|\/]\s*/).map(w => w.trim()).filter(Boolean);
          if (words.length) kwInput.value = words.join(' · ');
        });
      }
    })();
  </script>
</body>
</html>
