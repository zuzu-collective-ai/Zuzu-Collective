<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — Floor plan` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin" class="admin-back">← All couples</a>
        <h1 class="admin-title"><%= couple.display_name %></h1>
        <p class="admin-subtitle">
          <a href="/p/<%= couple.slug %>/floor-plan" target="_blank" rel="noopener">View live portal ↗</a>
        </p>
      </div>
      <a href="/admin/couples/<%= couple.id %>/floor-plan/new" class="admin-btn admin-btn--primary">+ Add space</a>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'floor-plan' }) %>

    <%- include('partials/flash', { flash }) %>

    <%
      const totalSqFt = spaces.reduce((s, sp) => s + (sp.square_feet || 0), 0);
      const fmtNum = n => Number(n || 0).toLocaleString('en-US');
    %>

    <% if (spaces.length > 0) { %>
      <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0 0 1.5rem;">
        <%= spaces.length %> space<%= spaces.length === 1 ? '' : 's' %>
        &nbsp;·&nbsp; total footprint <%= fmtNum(totalSqFt) %> sq ft
        &nbsp;·&nbsp; <a href="/admin/couples/<%= couple.id %>" class="admin-link">Edit headline copy</a>
      </p>
    <% } %>

    <% if (spaces.length === 0) { %>
      <p class="admin-empty">
        No floor-plan spaces yet for <%= couple.display_name %>.
        <a href="/admin/couples/<%= couple.id %>/floor-plan/new">Add the first one</a>.
      </p>
    <% } else { %>
      <ul class="admin-list">
        <% spaces.forEach(s => { %>
          <li class="admin-list-item">
            <a href="/admin/couples/<%= couple.id %>/floor-plan/<%= s.id %>" class="admin-list-link">
              <div class="admin-list-name"><em><%= s.title %></em></div>
              <div class="admin-list-meta">
                <% if (s.eyebrow) { %><span><%= s.eyebrow %></span><% } %>
                <% if (s.capacity)    { %><span>Capacity <%= s.capacity %></span><% } %>
                <% if (s.square_feet) { %><span><%= fmtNum(s.square_feet) %> sq ft</span><% } %>
                <span><%= s.zone_count %> zone<%= s.zone_count === 1 ? '' : 's' %></span>
                <span><%= s.key_count %> key item<%= s.key_count === 1 ? '' : 's' %></span>
              </div>
            </a>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </main>

</body>
</html>
