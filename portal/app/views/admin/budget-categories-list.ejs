<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: `${couple.display_name} — Budget` }) %>
<body class="admin-body">

  <%- include('partials/sidebar', { currentSection: 'couples' }) %>

  <main class="admin-main">
    <header class="admin-header">
      <div>
        <a href="/admin" class="admin-back">← All couples</a>
        <h1 class="admin-title"><%= couple.display_name %></h1>
        <p class="admin-subtitle">
          <a href="/p/<%= couple.slug %>/budget" target="_blank" rel="noopener">View live portal ↗</a>
        </p>
      </div>
      <a href="/admin/couples/<%= couple.id %>/budget/new" class="admin-btn admin-btn--primary">+ Add category</a>
    </header>

    <%- include('partials/couple-tabs', { couple, currentTab: 'budget' }) %>

    <%- include('partials/flash', { flash }) %>

    <%
      const fmt = c => '$' + ((c || 0) / 100).toLocaleString('en-US', { maximumFractionDigits: 0 });
      const totalEst    = categories.reduce((s, c) => s + (c.estimated_cents || 0), 0);
      const totalActual = categories.reduce((s, c) => s + (c.actual_cents || 0), 0);
    %>

    <p class="admin-empty" style="font-style: normal; color: var(--zz-finn-60); padding: 0 0 1.5rem;">
      Headline: <strong style="color: var(--zz-finn);"><%= fmt(couple.budget_total_cents) %></strong>
      &nbsp;·&nbsp; <%= categories.length %> categories total
      <% if (categories.length > 0) { %>
        &nbsp;·&nbsp; estimated <%= fmt(totalEst) %> &nbsp;·&nbsp; spent <%= fmt(totalActual) %>
      <% } %>
      &nbsp;·&nbsp; <a href="/admin/couples/<%= couple.id %>" class="admin-link">Edit headline</a>
    </p>

    <% if (categories.length === 0) { %>
      <p class="admin-empty">
        No budget categories yet for <%= couple.display_name %>.
        <a href="/admin/couples/<%= couple.id %>/budget/new">Add the first one</a>.
      </p>
    <% } else { %>
      <ul class="admin-list">
        <% categories.forEach(cat => { %>
          <li class="admin-list-item">
            <a href="/admin/couples/<%= couple.id %>/budget/<%= cat.id %>" class="admin-list-link">
              <div class="admin-list-name">
                <%= String(cat.category_number).padStart(2, '0') %> · <%= cat.title %><% if (cat.title_emphasis) { %> <em><%= cat.title_emphasis %></em><% } %>
              </div>
              <div class="admin-list-meta">
                <span>Est <%= fmt(cat.estimated_cents) %></span>
                <span>Actual <%= fmt(cat.actual_cents) %></span>
                <span><%= cat.line_count %> line<%= cat.line_count === 1 ? '' : 's' %></span>
              </div>
            </a>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </main>

</body>
</html>
