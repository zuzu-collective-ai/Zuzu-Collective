<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { couple, title: 'Floor Plan', extraStyles: ['palette.css', 'floor-plan.css'] }) %>
<body>

  <%- include('partials/topbar', { couple, currentPage }) %>

  <!-- ── Page header ─────────────────────────────────────────────────────── -->
  <section class="page-header">
    <span class="label page-eyebrow"><%= couple.display_name %></span>
    <h1 class="page-title">Floor Plan</h1>
    <p class="page-subtitle">
      The room, top down. Three venue spaces — the Ocean Lawn for the
      ceremony, the Upper Lawn and Loggia for cocktail hour, and the
      Garden Ballroom for the reception. Drawn to scale, keyed below.
    </p>
  </section>

  <!-- ── Summary stats ───────────────────────────────────────────────────── -->
  <section class="section floorplan-summary">
    <div class="summary-stats">
      <div class="stat">
        <div class="stat-label">Venue</div>
        <div class="stat-number">La Playa</div>
        <div class="stat-note">Carmel-by-the-Sea</div>
      </div>
      <div class="stat">
        <div class="stat-label">Spaces</div>
        <div class="stat-number">3</div>
        <div class="stat-note">Ceremony · Cocktails · Reception</div>
      </div>
      <div class="stat">
        <div class="stat-label">Footprint</div>
        <div class="stat-number">8,400</div>
        <div class="stat-note">Total square feet</div>
      </div>
      <div class="stat">
        <div class="stat-label">Walkthrough</div>
        <div class="stat-number">9.26</div>
        <div class="stat-note">Final at 10 AM</div>
      </div>
    </div>
  </section>

  <!-- ── Venue space 01 · Ceremony · Ocean Lawn ──────────────────────────── -->
  <article class="venue-space">
    <header class="venue-space-head">
      <span class="label venue-space-eyebrow">Phase 03 · 4:00 PM</span>
      <h2 class="venue-space-title"><em>The Ocean Lawn</em></h2>
      <div class="venue-space-meta">
        <span>Capacity 60</span>
        <span>2,400 sq ft</span>
        <span>Outdoor</span>
      </div>
    </header>

    <div class="floorplan-scene">

      <!-- ── Schematic ─────────────────────────────────────────────── -->
      <div class="floorplan" role="img" aria-label="Top-down schematic of the Ocean Lawn for the ceremony">
        <span class="compass">N&nbsp;↑</span>
        <span class="scale-bar">10 ft</span>

        <span class="edge-label is-top">Pacific Ocean</span>

        <!-- Arch — at the top, ocean side -->
        <div class="zone is-arch" style="top: 12%; left: 38%; width: 24%; height: 6%;">
          The arch
        </div>

        <!-- Officiant -->
        <div class="zone is-stage" style="top: 21%; left: 44%; width: 12%; height: 6%;">
          Officiant
        </div>

        <!-- Wedding party — left and right of arch -->
        <div class="zone is-chairs" style="top: 21%; left: 26%; width: 16%; height: 6%;">
          Bridal party · L
        </div>
        <div class="zone is-chairs" style="top: 21%; left: 58%; width: 16%; height: 6%;">
          Bridal party · R
        </div>

        <!-- Aisle -->
        <div class="zone is-aisle" style="top: 30%; left: 47%; width: 6%; height: 56%;">
          Aisle
        </div>

        <!-- Chairs — six rows of four per side -->
        <div class="zone is-chairs" style="top: 30%; left: 16%; width: 30%; height: 56%;">
          L · 24 chairs · 6 rows
        </div>
        <div class="zone is-chairs" style="top: 30%; left: 54%; width: 30%; height: 56%;">
          R · 24 chairs · 6 rows
        </div>

        <!-- Photographer mark -->
        <div class="zone is-stage" style="top: 90%; left: 46%; width: 8%; height: 6%;">
          Photographer
        </div>

        <!-- Confetti pouches staged -->
        <div class="zone is-service" style="top: 30%; left: 8%; width: 6%; height: 6%;">
          Confetti
        </div>
        <div class="zone is-service" style="top: 30%; left: 86%; width: 6%; height: 6%;">
          Confetti
        </div>
      </div>

      <!-- ── Key ──────────────────────────────────────────────────── -->
      <ol class="floorplan-key">
        <li>
          <span class="key-num">01</span>
          <div>
            <span class="key-name">The arch</span>
            <span class="key-detail">Olive branches, ivory ribbon — built on site by the florist 2:30 PM.</span>
          </div>
        </li>
        <li>
          <span class="key-num">02</span>
          <div>
            <span class="key-name">Officiant mark</span>
            <span class="key-detail">Reverend Diane Marquez, slightly off-center for the photo composition.</span>
          </div>
        </li>
        <li>
          <span class="key-num">03</span>
          <div>
            <span class="key-name">Bridal party flanks</span>
            <span class="key-detail">Three on each side — angled inward toward the couple.</span>
          </div>
        </li>
        <li>
          <span class="key-num">04</span>
          <div>
            <span class="key-name">The aisle</span>
            <span class="key-detail">4 ft wide, lined with bud vases on every other row.</span>
          </div>
        </li>
        <li>
          <span class="key-num">05</span>
          <div>
            <span class="key-name">Guest seating</span>
            <span class="key-detail">48 white folding chairs — six rows of four per side.</span>
          </div>
        </li>
        <li>
          <span class="key-num">06</span>
          <div>
            <span class="key-name">Photographer position</span>
            <span class="key-detail">Iris &amp; Light from the rear; second shooter floats the side aisles.</span>
          </div>
        </li>
        <li>
          <span class="key-num">07</span>
          <div>
            <span class="key-name">Confetti pouches</span>
            <span class="key-detail">Dried lavender in linen pouches — set on every other chair, both sides.</span>
          </div>
        </li>
      </ol>
    </div>
  </article>

  <!-- ── Venue space 02 · Cocktail Hour · Upper Lawn & Loggia ───────────── -->
  <article class="venue-space">
    <header class="venue-space-head">
      <span class="label venue-space-eyebrow">Phase 04 · 4:30 PM</span>
      <h2 class="venue-space-title"><em>The Upper Lawn &amp; Loggia</em></h2>
      <div class="venue-space-meta">
        <span>Capacity 120</span>
        <span>2,200 sq ft</span>
        <span>Outdoor &amp; covered</span>
      </div>
    </header>

    <div class="floorplan-scene">

      <div class="floorplan" role="img" aria-label="Top-down schematic of the Upper Lawn and Loggia for cocktail hour">
        <span class="compass">N&nbsp;↑</span>
        <span class="scale-bar">10 ft</span>

        <span class="edge-label is-top">Bougainvillea wall</span>

        <!-- Bar — left side along the loggia -->
        <div class="zone is-bar" style="top: 30%; left: 4%; width: 8%; height: 40%;">
          Main bar
        </div>

        <!-- String trio — under the bougainvillea -->
        <div class="zone is-stage" style="top: 10%; left: 38%; width: 24%; height: 8%;">
          Carmel Strings · trio
        </div>

        <!-- Hors d'oeuvres pass stations -->
        <div class="zone is-service" style="top: 30%; left: 24%; width: 12%; height: 8%;">
          Pass · L
        </div>
        <div class="zone is-service" style="top: 30%; left: 64%; width: 12%; height: 8%;">
          Pass · R
        </div>

        <!-- High-tops — six scattered cocktail tables -->
        <div class="zone is-hightop" style="top: 48%; left: 22%; width: 8%; aspect-ratio: 1;">01</div>
        <div class="zone is-hightop" style="top: 48%; left: 38%; width: 8%; aspect-ratio: 1;">02</div>
        <div class="zone is-hightop" style="top: 48%; left: 54%; width: 8%; aspect-ratio: 1;">03</div>
        <div class="zone is-hightop" style="top: 48%; left: 70%; width: 8%; aspect-ratio: 1;">04</div>
        <div class="zone is-hightop" style="top: 70%; left: 30%; width: 8%; aspect-ratio: 1;">05</div>
        <div class="zone is-hightop" style="top: 70%; left: 62%; width: 8%; aspect-ratio: 1;">06</div>

        <!-- Cake preview / signature pour station -->
        <div class="zone is-service" style="top: 30%; left: 84%; width: 12%; height: 14%;">
          Signature pour
        </div>

        <!-- Path doorway to reception — inset 1% so the dashed marker
             reads cleanly above the schematic border. -->
        <div class="zone is-door is-bottom-edge" style="bottom: 1%; left: 44%; width: 12%; height: 5%;">
          To reception
        </div>

      </div>

      <ol class="floorplan-key">
        <li>
          <span class="key-num">01</span>
          <div>
            <span class="key-name">Main bar</span>
            <span class="key-detail">Two bartenders — Carmel mule and sage gimlet on the chalkboard.</span>
          </div>
        </li>
        <li>
          <span class="key-num">02</span>
          <div>
            <span class="key-name">Carmel Strings · trio</span>
            <span class="key-detail">Acoustic, no amp — set under the bougainvillea, 4:55 PM start.</span>
          </div>
        </li>
        <li>
          <span class="key-num">03</span>
          <div>
            <span class="key-name">Hors d'oeuvres pass stations</span>
            <span class="key-detail">Six passed bites on linen trays — staged left and right of the trio.</span>
          </div>
        </li>
        <li>
          <span class="key-num">04</span>
          <div>
            <span class="key-name">Cocktail high-tops</span>
            <span class="key-detail">Six 32" rounds with linen drapes and a single bud vase each.</span>
          </div>
        </li>
        <li>
          <span class="key-num">05</span>
          <div>
            <span class="key-name">Signature pour station</span>
            <span class="key-detail">A small batched cocktail run by the captain — no line, no queue.</span>
          </div>
        </li>
        <li>
          <span class="key-num">06</span>
          <div>
            <span class="key-name">Path to the Garden Ballroom</span>
            <span class="key-detail">Lit at 5:15 PM with hurricane lanterns lining the way.</span>
          </div>
        </li>
      </ol>
    </div>
  </article>

  <!-- ── Venue space 03 · Reception · Garden Ballroom ────────────────────── -->
  <article class="venue-space">
    <header class="venue-space-head">
      <span class="label venue-space-eyebrow">Phase 05 · 5:30 PM</span>
      <h2 class="venue-space-title"><em>The Garden Ballroom</em></h2>
      <div class="venue-space-meta">
        <span>Capacity 124</span>
        <span>3,800 sq ft</span>
        <span>Indoor</span>
      </div>
    </header>

    <div class="floorplan-scene">

      <div class="floorplan" role="img" aria-label="Top-down schematic of the Garden Ballroom for the reception">
        <span class="compass">N&nbsp;↑</span>
        <span class="scale-bar">10 ft</span>

        <!-- Catering doors — kept inset 1% so the dashed edge marker
             doesn't compete with the schematic border itself. -->
        <div class="zone is-door" style="top: 1%; left: 70%; width: 16%; height: 4%;">
          Catering
        </div>

        <!-- DJ booth — top center, short label so it fits the 12% width -->
        <div class="zone is-stage" style="top: 10%; left: 44%; width: 12%; height: 7%;">
          DJ
        </div>

        <!-- Bar — left edge -->
        <div class="zone is-bar" style="top: 26%; left: 3%; width: 6%; height: 40%;">
          Bar
        </div>

        <!-- Cake / sweets table — right corner -->
        <div class="zone is-service" style="top: 12%; left: 86%; width: 11%; height: 12%;">
          Cake
        </div>

        <!-- Dance floor — center -->
        <div class="zone is-dance" style="top: 38%; left: 40%; width: 22%; height: 24%;">
          Dance
        </div>

        <!-- Round tables — only the number inside; names live in the key
             so the small circles don't have to fit two pieces of text. -->
        <!-- Top row -->
        <div class="zone is-table" style="top: 22%; left: 16%; width: 11%; aspect-ratio: 1;">02</div>
        <div class="zone is-table" style="top: 22%; left: 30%; width: 11%; aspect-ratio: 1;">03</div>
        <div class="zone is-table" style="top: 22%; left: 60%; width: 11%; aspect-ratio: 1;">04</div>
        <div class="zone is-table" style="top: 22%; left: 74%; width: 11%; aspect-ratio: 1;">05</div>

        <!-- Middle row -->
        <div class="zone is-table" style="top: 42%; left: 18%; width: 11%; aspect-ratio: 1;">06</div>
        <div class="zone is-table" style="top: 42%; left: 71%; width: 11%; aspect-ratio: 1;">07</div>

        <!-- Head table — oval, just the number -->
        <div class="zone is-head-table" style="top: 66%; left: 36%; width: 30%; height: 8%;">01</div>

        <!-- Bottom row -->
        <div class="zone is-table" style="top: 78%; left: 18%; width: 11%; aspect-ratio: 1;">08</div>
        <div class="zone is-table" style="top: 78%; left: 71%; width: 11%; aspect-ratio: 1;">09</div>
        <div class="zone is-table" style="top: 78%; left: 4%; width: 11%; aspect-ratio: 1;">10</div>

        <!-- Restroom — pulled inset 1% so the edge label doesn't crowd it -->
        <div class="zone is-service" style="top: 50%; right: 1%; width: 4%; height: 16%;">
          WC
        </div>

        <!-- Guest entrance from cocktail path -->
        <div class="zone is-door is-bottom-edge" style="bottom: 1%; left: 42%; width: 16%; height: 4%;">
          Entrance
        </div>

      </div>

      <ol class="floorplan-key">
        <li>
          <span class="key-num">01</span>
          <div>
            <span class="key-name">Cypress · the head table</span>
            <span class="key-detail">Oval, eight seats — the couple, both sets of parents, sister and brother. Faces the dance floor.</span>
          </div>
        </li>
        <li>
          <span class="key-num">02</span>
          <div>
            <span class="key-name">DJ · West Coast Sound</span>
            <span class="key-detail">Booth at the back of the dance floor, low profile, no logo banners.</span>
          </div>
        </li>
        <li>
          <span class="key-num">03</span>
          <div>
            <span class="key-name">Bar</span>
            <span class="key-detail">12-foot service bar along the loggia wall. Two bartenders + a barback.</span>
          </div>
        </li>
        <li>
          <span class="key-num">04</span>
          <div>
            <span class="key-name">Cake table</span>
            <span class="key-detail">Three-tier almond cake with fig &amp; honey. Wheeled to dance-floor edge for the cut at 7:45.</span>
          </div>
        </li>
        <li>
          <span class="key-num">05</span>
          <div>
            <span class="key-name">Dance floor</span>
            <span class="key-detail">22 ft × 24 ft parquet over the existing carpet. Centerpiece string lights overhead.</span>
          </div>
        </li>
        <li>
          <span class="key-num">06</span>
          <div>
            <span class="key-name">Round tables</span>
            <span class="key-detail">Nine 60" rounds (8–10 seats each). Linen runners, taper candles, low ivory florals.</span>
          </div>
        </li>
        <li>
          <span class="key-num">07</span>
          <div>
            <span class="key-name">Catering ingress</span>
            <span class="key-detail">Back-of-house double doors — used for plated dinner service and late-night bites.</span>
          </div>
        </li>
        <li>
          <span class="key-num">08</span>
          <div>
            <span class="key-name">Guest entrance</span>
            <span class="key-detail">From the lit garden path. Place cards at the entry hung on a brass rod with linen ribbon.</span>
          </div>
        </li>
        <li>
          <span class="key-num">09</span>
          <div>
            <span class="key-name">Restrooms</span>
            <span class="key-detail">Just off the right-hand wall — signage in the venue's house typeface.</span>
          </div>
        </li>
      </ol>
    </div>
  </article>


  <%- include('partials/footer', { couple }) %>

</body>
</html>
