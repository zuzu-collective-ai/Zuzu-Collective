<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { couple, title: 'Timeline', extraStyles: ['palette.css', 'timeline.css'] }) %>
<body>

  <%- include('partials/topbar', { couple, currentPage }) %>

  <%
    const wd = new Date(couple.wedding_date);
    const monthShort = wd.toLocaleDateString('en-US', { month: '2-digit', timeZone: 'UTC' });
    const dayShort   = wd.toLocaleDateString('en-US', { day: '2-digit',  timeZone: 'UTC' });
    const dateShort  = `${monthShort}.${dayShort}`;
    // Assemble manually so the order matches the mockup exactly
    // ("Saturday, October 2026") regardless of Intl locale ordering.
    const weekdayName = wd.toLocaleDateString('en-US', { weekday: 'long', timeZone: 'UTC' });
    const monthName   = wd.toLocaleDateString('en-US', { month:   'long', timeZone: 'UTC' });
    const yearStr     = wd.toLocaleDateString('en-US', { year:    'numeric', timeZone: 'UTC' });
    const dateLong    = `${weekdayName}, ${monthName} ${yearStr}`;
    // The phase-count copy adjusts to whatever's in the DB rather than
    // hardcoding "Six phases".
    const phaseCountWord = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine', 'Ten'][summary.phaseCount] || summary.phaseCount;
  %>

  <!-- ── Page header ─────────────────────────────────────────────────────── -->
  <section class="page-header">
    <span class="label page-eyebrow"><%= couple.display_name %></span>
    <h1 class="page-title">Timeline</h1>
    <p class="page-subtitle">
      The day, hour by hour. <%= phaseCountWord %> phase<%= summary.phaseCount === 1 ? '' : 's' %> —
      built from the vendor contracts and locked two weeks before the wedding.
    </p>
  </section>

  <!-- ── Summary stats ───────────────────────────────────────────────────── -->
  <section class="section timeline-summary">
    <div class="summary-stats">
      <div class="stat">
        <div class="stat-label">Date</div>
        <div class="stat-number"><%= dateShort %></div>
        <div class="stat-note"><%= dateLong %></div>
      </div>
      <% if (couple.timeline_ceremony_time || couple.timeline_ceremony_note) { %>
        <div class="stat">
          <div class="stat-label">Ceremony</div>
          <div class="stat-number"><%= couple.timeline_ceremony_time || '' %></div>
          <% if (couple.timeline_ceremony_note) { %>
            <div class="stat-note"><%= couple.timeline_ceremony_note %></div>
          <% } %>
        </div>
      <% } %>
      <div class="stat">
        <div class="stat-label">Events</div>
        <div class="stat-number"><%= summary.eventCount %></div>
        <div class="stat-note">Across <%= summary.phaseCount %> phase<%= summary.phaseCount === 1 ? '' : 's' %></div>
      </div>
      <% if (couple.timeline_lastcall_time || couple.timeline_lastcall_note) { %>
        <div class="stat">
          <div class="stat-label">Last call</div>
          <div class="stat-number"><%= couple.timeline_lastcall_time || '' %></div>
          <% if (couple.timeline_lastcall_note) { %>
            <div class="stat-note"><%= couple.timeline_lastcall_note %></div>
          <% } %>
        </div>
      <% } %>
    </div>
  </section>

  <!-- ── Phases ──────────────────────────────────────────────────────────── -->
  <div class="reorder-bar">
    <button id="timeline-edit-btn" class="reorder-btn">Edit order</button>
  </div>
  <section id="phases-list" class="phases">
    <% phases.forEach(phase => {
         const events = eventsByPhase.get(phase.id) || [];
         const variantClass = phase.variant === 'ceremony' ? ' phase--ceremony'
                            : phase.variant === 'sendoff'  ? ' phase--sendoff'
                            : '';
    %>
      <article class="phase<%= variantClass %>" data-phase="<%= phase.id %>">
        <header class="phase-head">
          <span class="phase-num">Phase <%= String(phase.phase_number).padStart(2, '0') %></span>
          <% if (phase.window_text) { %>
            <span class="phase-window"><%= phase.window_text %></span>
          <% } %>
          <span class="phase-count"><%= events.length %> event<%= events.length === 1 ? '' : 's' %></span>
          <h2 class="phase-title"><em><%= phase.title %></em></h2>
          <% if (phase.note_text) { %>
            <p class="phase-note"><%= phase.note_text %></p>
          <% } %>
        </header>

        <% if (events.length > 0) { %>
          <ul class="event-list">
            <% events.forEach(ev => { %>
              <li class="event" data-event="<%= ev.id %>">
                <span class="event-time"><%= ev.time_text %><% if (ev.meridiem) { %><span class="event-time-meridiem"><%= ev.meridiem %></span><% } %></span>
                <div class="event-body">
                  <h3 class="event-title"><%= ev.title %></h3>
                  <% const hasMeta = ev.where_label || ev.lead_label || ev.with_label; %>
                  <% if (hasMeta) { %>
                    <div class="event-meta">
                      <% if (ev.where_label) { %>
                        <span class="event-meta-item"><span class="event-meta-label">Where</span><span class="event-meta-value"><%= ev.where_label %></span></span>
                      <% } %>
                      <% if (ev.with_label) { %>
                        <span class="event-meta-item"><span class="event-meta-label">With</span><span class="event-meta-value"><%= ev.with_label %></span></span>
                      <% } %>
                      <% if (ev.lead_label) { %>
                        <span class="event-meta-item"><span class="event-meta-label">Lead</span><span class="event-meta-value"><%= ev.lead_label %></span></span>
                      <% } %>
                    </div>
                  <% } %>
                  <% if (ev.note_text) { %>
                    <p class="event-note"><%= ev.note_text %></p>
                  <% } %>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </article>
    <% }) %>
  </section>


  <%- include('partials/footer', { couple }) %>

  <style>
    .reorder-bar { display:flex; justify-content:flex-end; padding:0 var(--space-lg) var(--space-sm); }
    .reorder-btn {
      font-family: var(--zz-mono); font-size: 0.65rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--zz-finn-60); background: none;
      border: 1px solid var(--zz-finn-20); padding: 0.45em 1.1em; cursor: pointer;
      transition: color 0.15s, border-color 0.15s; border-radius: 2px;
    }
    .reorder-btn:hover,
    .reorder-btn.is-active { color: var(--zz-finn); border-color: var(--zz-finn-60); }
    #phases-list.is-editing [data-phase] { outline: 1px dashed var(--zz-finn-20); outline-offset: -4px; }
    #phases-list.is-editing .phase-head { cursor: grab; user-select: none; }
    #phases-list.is-editing .phase-head:active { cursor: grabbing; }
    #phases-list.is-editing .event-time { cursor: grab; user-select: none; }
    #phases-list.is-editing .event-time::before { content: '⠿ '; opacity: 0.4; }
    #phases-list.is-editing .event-time:active { cursor: grabbing; }
    .reorder-ghost { opacity: 0.3; }
    .reorder-chosen { position: relative; z-index: 10; }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script>
  (function () {
    var KEY_PHASES = 'zuzu-timeline-phases-<%= couple.slug %>';
    var KEY_EVENTS = 'zuzu-timeline-events-<%= couple.slug %>';
    var phaseList  = document.getElementById('phases-list');
    var btn        = document.getElementById('timeline-edit-btn');
    if (!phaseList || !btn) return;
    var phaseSortable  = null;
    var eventSortables = [];

    // Restore phase order
    try {
      var savedPhases = JSON.parse(localStorage.getItem(KEY_PHASES));
      if (Array.isArray(savedPhases)) {
        savedPhases.forEach(function (id) {
          var el = phaseList.querySelector('[data-phase="' + id + '"]');
          if (el) phaseList.appendChild(el);
        });
      }
    } catch (_) {}

    // Restore event orders per phase
    try {
      var savedEvents = JSON.parse(localStorage.getItem(KEY_EVENTS));
      if (savedEvents && typeof savedEvents === 'object') {
        Object.keys(savedEvents).forEach(function (phaseId) {
          var phase = phaseList.querySelector('[data-phase="' + phaseId + '"]');
          if (!phase) return;
          var ul = phase.querySelector('.event-list');
          if (!ul) return;
          savedEvents[phaseId].forEach(function (id) {
            var el = ul.querySelector('[data-event="' + id + '"]');
            if (el) ul.appendChild(el);
          });
        });
      }
    } catch (_) {}

    function savePhaseOrder() {
      var order = Array.from(phaseList.querySelectorAll('[data-phase]')).map(function (el) { return el.dataset.phase; });
      try { localStorage.setItem(KEY_PHASES, JSON.stringify(order)); } catch (_) {}
    }

    function saveEventOrders() {
      var orders = {};
      phaseList.querySelectorAll('[data-phase]').forEach(function (phase) {
        var ul = phase.querySelector('.event-list');
        if (!ul) return;
        orders[phase.dataset.phase] = Array.from(ul.querySelectorAll('[data-event]')).map(function (el) { return el.dataset.event; });
      });
      try { localStorage.setItem(KEY_EVENTS, JSON.stringify(orders)); } catch (_) {}
    }

    btn.addEventListener('click', function () {
      var editing = phaseList.classList.toggle('is-editing');
      btn.textContent = editing ? 'Done' : 'Edit order';
      btn.classList.toggle('is-active', editing);

      if (editing) {
        phaseSortable = Sortable.create(phaseList, {
          animation: 200,
          handle: '.phase-head',
          ghostClass: 'reorder-ghost',
          chosenClass: 'reorder-chosen',
          onEnd: savePhaseOrder,
        });
        phaseList.querySelectorAll('[data-phase]').forEach(function (phase) {
          var ul = phase.querySelector('.event-list');
          if (!ul) return;
          eventSortables.push(Sortable.create(ul, {
            animation: 150,
            handle: '.event-time',
            ghostClass: 'reorder-ghost',
            chosenClass: 'reorder-chosen',
            onEnd: saveEventOrders,
          }));
        });
      } else {
        if (phaseSortable) { phaseSortable.destroy(); phaseSortable = null; }
        eventSortables.forEach(function (s) { s.destroy(); });
        eventSortables = [];
      }
    });
  })();
  </script>

</body>
</html>
