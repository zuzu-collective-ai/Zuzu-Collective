# Local dev environment for the Zuzu portal.
# Copy this to .env and fill in your real values.

# Postgres connection. On Render this is set automatically from the
# linked database service. Locally you can point at a Docker postgres
# or a remote dev db.
DATABASE_URL=postgres://localhost:5432/zuzu_portal

# Port the Express app listens on. Render sets this automatically.
PORT=3000

# Admin tool. ADMIN_PASSWORD is whatever string Zoe wants to use to
# sign in at /admin/login. SESSION_SECRET signs the auth cookie —
# pick any long random string locally; Render generates one for you.
ADMIN_PASSWORD=change-me-locally
SESSION_SECRET=local-dev-only-replace-with-anything-long

# Anthropic API key for the AI features (budget allocator, palette generator,
# checklist generator, vendor outreach). Without it the AI buttons are
# disabled with a "missing key" hint — the rest of the app still works.
ANTHROPIC_API_KEY=

# First-view email notifications. When a couple's portal is opened for the
# first time, the app sends an email to NOTIFY_EMAIL via SendGrid.
# NOTIFY_EMAIL must be a verified sender in your SendGrid account.
# Leave both blank to disable notifications.
SENDGRID_API_KEY=
NOTIFY_EMAIL=

# Public URL of the app — included in first-view notification emails.
# e.g. https://portal.zuzucollective.com
APP_URL=http://localhost:3000

# Analytics IP hashing salt. Any random string works. Render auto-generates
# one; locally you can leave this unset (falls back to a dev default).
ANALYTICS_SALT=
